<odoo>
    <record id="remove_brand_from_product_tree" model="ir.ui.view">
        <field name="name">product.template.tree.remove.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="cloudmen_po_report.view_list_product_brand"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='brand']" position="replace">
                <!-- removed brand field from product tree -->
            </xpath>
        </field>
    </record>
</odoo>
