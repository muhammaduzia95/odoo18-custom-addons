<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="inherit_product_template_only_form_view" model="ir.ui.view">
        <field name="name">inherit_product_template_only_form_view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="brand"/>
            </xpath>
        </field>
    </record>

    <record id="view_search_product_brand" model="ir.ui.view">
        <field name="name">product.template.search.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="replace">
                <field name="name" string="Product"
                       filter_domain="['|', '|', '|', '|',
                                      ('default_code', 'ilike', self),
                                      ('brand', 'ilike', self),
                                      ('product_variant_ids.default_code', 'ilike', self),
                                      ('name', 'ilike', self),
                                      ('barcode', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>

    <record id="view_list_product_brand" model="ir.ui.view">
        <field name="name">product.template.tree.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="brand"/>
            </xpath>
        </field>
    </record>

</odoo>