<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="header_layout_standard_custom">
        <t t-set="company" t-value="user.company_id"/>
<div class="header">

            <div class="row">
                <div class="col-6">
                    <table>
                        <tbody>
                            <tr>
                                <td style="border: 1px solid white;" rowspan="4">
                                    <img src="/cloudmen_eme_quotation/static/img/img_1.png" loading="lazy"
                                         style="width: 155px; height: 70px;"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="col-6">
                    <table style="margin-left: auto;border: 1px solid white;">
                        <tbody>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 1px;
                                            white-space: nowrap;
                                            text-align:right;
                                        ">Engineering Marketing Est.
                                </td>
                            </tr>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 1px;
                                            white-space: nowrap;
                                            text-align:right;
                                        ">Burj Al Arab, 203, Hamdan St.
                                </td>
                            </tr>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 5px;
                                            white-space: nowrap;
                                            text-align:right;
                                        ">P.O. Box 3622, Abu Dhabi, UAE

                                </td>
                            </tr>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 1px;
                                            white-space: nowrap;
                                            text-align:right;
                                        ">+971 (0) 2 677 5022
                                </td>
                            </tr>
                            <tr>
                                <td style="pointer-events: none;border: 1px solid white;padding: 1px;white-space: nowrap;text-align:right;">
                                    info@eme-me.com
                                </td>
                            </tr>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 1px;
                                            white-space: nowrap;
                                            text-align:right;
                                            pointer-events: none;
                                        ">www.eme-me.com
                                </td>
                            </tr>
                            <tr>
                                <td style="
                                            border: 1px solid white;
                                            padding: 1px;
                                            white-space: nowrap;
                                            text-align:right;
                                        ">TRN: 100358353900003
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
        <div t-attf-class="article o_report_layout_standard o_table_standard o_company_#{company.id}_layout o_snail_mail {{'o_report_layout_background' if company.layout_background != 'Blank' else ''}}"
             t-attf-style="background-image: url({{ 'data:image/png;base64,%s' % company.layout_background_image.decode('utf-8') if company.layout_background_image and company.layout_background == 'Custom' else
                           '/base/static/img/demo_logo_report.png' if company.layout_background == 'Demo logo' else ''}});"
             t-att-data-oe-model="o and o._name"
             t-att-data-oe-id="o and o.id"
             t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-call="web.address_layout"/>
            <h2 t-out="layout_document_title"/>
            <t t-out="0"/>
        </div>

        <div class="footer" >
            <div class=" border-top text-center pt-2" style="margin-bottom: -25px;">
                <div t-field="company.report_footer" style="margin-bottom: -5px;"/>
                <div class="text-center" style="margin-bottom: -25px;">
                    <div t-if="report_type == 'pdf' and display_name_in_footer" t-out="o.name">(document name)</div>
                    <div t-if="report_type == 'pdf'" style="margin-bottom: -5px;">Page
                        <span class="page"/>
                        /
                        <span class="topage"/>
                    </div>
                </div>
            </div>
        </div>

    </template>

</odoo>