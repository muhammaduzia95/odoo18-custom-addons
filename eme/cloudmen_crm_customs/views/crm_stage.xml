<odoo>
    <record id="view_crm_stages_type"
            model="ir.ui.view">
        <field name="name">crm.stages.types</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='team_id']"
                   position="after">
                <field name="is_tender_stage"/>
            </xpath>
        </field>
    </record>
</odoo>
