<odoo>
    <record id="paperformat_eme_letter_head"
            model="report.paperformat">
        <field name="name">Paperformat EME Letter Head</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">45</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">40</field>
        <field name="dpi">90</field>
    </record>


    <template id="layout_eme_letter_head">

        <div class="header">
            <div class="row" style="display: table; width: 100%; margin-bottom: 20px;">
                <div class="col-4" style="display: table-cell; width: 30%; vertical-align: middle;">
                    <img t-att-src="image_data_uri(doc.company_id.logo)"
                         alt="Company Logo"
                         style="width: 155px; height: 75px;"/>
                </div>
                <div class="col-8" style="display: table-cell; width: 70%; vertical-align: middle; text-align: right;">
                    <table style="margin-left: auto; border-collapse: collapse; line-height: 1.4; border: 1px solid white;">
                        <tbody>
                            <tr>
                                <td style="padding: 2px 0; font-weight: bold; font-size: 14px; border: 1px solid white;">
                                    Engineering Marketing Est.
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 12px; border: 1px solid white;">
                                    Burj Al Arab, 203, Hamdan St.
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 12px; border: 1px solid white;">
                                    P.O. Box 3622, Abu Dhabi, UAE
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 12px; border: 1px solid white;">
                                    Tel: +971 (0) 2 677 5022
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 12px; border: 1px solid white;">
                                    Email: info@eme-me.com
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 12px; border: 1px solid white;">
                                    Web: www.eme-me.com
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 0; font-size: 11px; color: #666; border: 1px solid white;">
                                    TRN: 100358353900003
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="article" style="padding-top: 25px;">
            <t t-raw="0"/>
        </div>

        <div class="footer">
        </div>
    </template>


    <template id="template_eme_letter_head">
        <t t-call="web.html_container">
            <t t-call="eme_letter_head.layout_eme_letter_head">
                <div class="page">
                    <t t-foreach="docs" t-as="doc">
                    </t>
                </div>
            </t>
        </t>
    </template>


    <record id="report_eme_letter_head" model="ir.actions.report">
        <field name="name">EME Letter Head</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">eme_letter_head.template_eme_letter_head</field>
        <field name="report_file">eme_letter_head.template_eme_letter_head</field>
        <field name="print_report_name">'Simplified Tax Invoice - %s' % object.name</field>
        <!--        <field name="print_report_name">'Expenses - %s - %s' % (object.employee_id.name, (object.name).replace('/', ''))-->
        <!--        </field>-->
        <!--        <field name="attachment">'certification.pdf'</field>-->
        <!--        <field name="attachment">'ISR-' + object.name + '.pdf'</field>-->
        <!--        <field name="attachment_use">True</field>-->
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="eme_letter_head.paperformat_eme_letter_head"/>
        <!--        <field name="groups_id" eval="[(4, ref('sale.group_proforma_sales'))]"/>-->
        <!--        <field name="multi">True</field>-->
    </record>
</odoo>