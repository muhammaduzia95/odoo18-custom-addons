<odoo>

    <!-- === Invoice Form === -->
    <record id="view_move_form_inherit_customer_po" model="ir.ui.view">
        <field name="name">account.move.form.inherit.customer.po</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='delivery_date']" position="after">
                <field name="customer_po_no" invisible="move_type != 'out_invoice'"/>
                <field name="customer_po_date" invisible="move_type != 'out_invoice'"/>
            </xpath>

        </field>
    </record>

</odoo>
