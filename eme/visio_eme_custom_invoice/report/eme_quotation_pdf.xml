<!--D:\Visiomate\Odoo\odoo18\custom_addons\eme\visio_eme_custom_invoice\report\eme_quotation_pdf.xml-->
<odoo>

    <template id="eme_quotation_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <!-- ================= COVER (BLANK HEADER) ================= -->
                <t t-set="is_cover_page" t-value="True"/>
                <t t-set="is_quotation" t-value="False"/>
                <t t-call="web.external_layout">
                    <t t-call="visio_eme_custom_invoice.eme_quotation_cover_page"/>
                </t>

                <!-- ================= CONTENT (QUOTATION HEADER) ================= -->
                <t t-set="is_cover_page" t-value="False"/>
                <t t-set="is_quotation" t-value="True"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="padding-left:13mm; padding-right:13mm;">

                            <!-- ======= INFO BLOCK ======= -->
                            <table style="width:100%; border-color:white; margin-top:15px; font-size:13px;">
                                <tr>
                                    <!-- LEFT SIDE: Address below logo -->
                                    <td style="font-size:14px; width:60%; vertical-align:top; text-align:left; border-color:white;">
                                        <p style="margin:0px 0;">
                                            <t t-esc="o.company_id.street or ''"/>
                                        </p>
                                        <p style="margin:0px 0;">
                                            <t t-if="o.company_id.zip">
                                                P.O. Box
                                                <t t-esc="o.company_id.zip"/>
                                            </t>
                                            <t t-if="o.company_id.city">
                                                ,
                                                <t t-esc="o.company_id.city"/>
                                            </t>
                                            <t t-if="o.company_id.country_id">
                                                ,
                                                <t t-esc="o.company_id.country_id.code"/>
                                            </t>
                                        </p>
                                        <p style="margin:0px 0;">
                                            <t t-esc="o.company_id.phone or ' '"/>
                                        </p>
                                        <p style="margin:0px 0;">
                                            <t t-esc="o.company_id.email or ' '"/>
                                        </p>
                                        <p style="margin:0px 0;">
                                            <t t-if="o.company_id.website">
                                                <t t-esc="o.company_id.website"/>
                                            </t>
                                        </p>
                                        <p style="margin:0px 0;" t-if="o.company_id.vat">
                                            TRN:
                                            <t t-esc="o.company_id.vat"/>
                                        </p>
                                    </td>

                                    <!-- RIGHT SIDE: Both info tables -->
                                    <td style="width:40%; vertical-align:top; text-align:left; border-color:white;">
                                        <!-- FIRST TABLE -->
                                        <table style="width:100%; border-color:white;">
                                            <tr>
                                                <td style="width:40%;">Quotation No.:</td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <t t-if="o.name">
                                                            <t t-esc="o.name"/>
                                                        </t>
                                                        <t t-if="not o.name"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="width:40%;">Quotation Date:</td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <t t-if="pi_date">
                                                            <t t-esc="pi_date.strftime('%d %b %Y')"/>
                                                        </t>
                                                        <t t-if="not pi_date"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="">Valid Until:</td>
                                                <td style="">
                                                    <strong>
                                                        <t t-if="due_date">
                                                            <t t-esc="due_date.strftime('%d %b %Y')"/>
                                                        </t>
                                                        <t t-if="not due_date"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </table>

                                        <!-- SECOND TABLE -->
                                        <table style="width:100%; border-color:white; margin-top:8px;">
                                            <tr>
                                                <td style="">Payment Terms:</td>
                                                <td style="">
                                                    <strong>
                                                        <t t-esc="payment_terms or ' '"/>
                                                    </strong>
                                                </td>
                                            </tr>

                                            <tr>
                                                <td style="width:40%;">Sales Rep.:</td>
                                                <td style="width:60%;">
                                                    <strong>
                                                        <t t-esc="salesperson or ' '"/>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- ======= BILL TO / SHIP TO SECTION ======= -->
                            <table style="width:100%; border:none; border-collapse:collapse; margin-top:15px; font-size:13px;">
                                <tr>
                                    <!-- === BILL TO === -->
                                    <td style="width:55%; margin-right:30px; vertical-align:top; border:1px solid black; padding:0;">
                                        <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                            <strong>Bill To:</strong>
                                        </div>
                                        <div style="padding:6px;">
                                            <p style="margin:2px 0; margin-bottom: 10px;">
                                                <strong>
                                                    <t t-esc="customer_name or '  '"/>
                                                </strong>
                                            </p>
                                            <p style="margin:2px 0;">
                                                <t t-esc="customer_address or '  '"/>
                                            </p>
                                            <p style="margin:2px 0;">Customer TRN:
                                                <strong>
                                                    <t t-esc="customer_trn or '  '"/>
                                                </strong>
                                            </p>
                                            <p style="margin:2px 0;">Customer Phone:
                                                <strong>
                                                    <t t-esc="customer_phone or '  '"/>
                                                </strong>
                                            </p>
                                            <p style="margin:2px 0;">Customer Email:
                                                <strong>
                                                    <t t-esc="customer_email or '  '"/>
                                                </strong>
                                            </p>
                                        </div>
                                    </td>
                                    <td style="width:5%; border:0px solid white;">
                                    </td>

                                    <!-- === SHIP TO === -->
                                    <td style="width:40%; vertical-align:top; border:1px solid black; padding:0;">
                                        <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                            <strong>Ship To:</strong>
                                        </div>
                                        <div style="padding:6px;">
                                            <p style="margin:2px 0;">
                                                <!--                                <t t-esc="ship_to_address"/>-->
                                                <t t-esc="customer_address"/>
                                            </p>
                                            <p style="margin:2px 0;">Ship Date:
                                                <strong>
                                                    <t t-esc="ship_date"/>
                                                </strong>
                                            </p>
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            <table style="width:100%; border:none; border-collapse:collapse; margin-top:15px; font-size:13px;">

                                <!-- Row 1: Other Info -->
                                <tr>
                                    <td style="width:100%; vertical-align:top; border:1px solid white; padding:0;">
                                        <div style="padding:6px;">
                                            <p style="margin:2px 0;">
                                                <strong>Att:</strong>
                                                <t t-esc="attention_name or ' '"/>
                                            </p>
                                            <p style="margin:2px 0;">
                                                <strong>Project Name:</strong>
                                                <t t-esc="project_name or ' '"/>
                                            </p>
                                            <p style="margin:2px 0;">
                                                <strong>Project Consultant:</strong>
                                                <t t-esc="consultant_name or ' '"/>
                                            </p>
                                            <p style="margin:2px 0;">
                                                <strong>Subject:</strong>
                                                <t t-esc="subject or ' '"/>
                                            </p>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Row 2: Details -->
                                <tr>
                                    <td style="width:100%; vertical-align:top; border:1px solid white; padding:0;">
                                        <div style="padding:6px;">
                                            <p style="margin:2px 0;">
                                                <t t-esc="details or ' '"/>
                                            </p>
                                        </div>
                                    </td>
                                </tr>

                            </table>

                            <!-- ======= MAIN INVOICE LINES TABLE ======= -->
                            <div style="height:550px;">
                                <table style="width:100%; border-collapse:collapse; margin-top:30px; font-size:13px;">
                                    <thead>
                                        <tr style="font-family: Arial, sans-serif; background-color:#d9d9d9; text-align:center; height:28px;">

                                            <th style="border:1px solid black; padding:2px 3px; text-align:center; width:25px;">
                                                <strong>#</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center;">
                                                <strong>Item Code</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center; width:40%;">
                                                <strong>Description</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center;">
                                                <strong>UoM</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center;">
                                                <strong>Qty</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center;">
                                                <strong>Unit Price</strong>
                                            </th>

                                            <th style="border:1px solid black; padding:2px 6px; text-align:center;">
                                                <strong>Total</strong>
                                            </th>

                                        </tr>
                                    </thead>

                                    <tbody>
                                        <t t-foreach="line_data" t-as="l">
                                            <tr style="page-break-inside: avoid;">
                                                <td style="border:1px solid black; text-align:center; padding:4px;">
                                                    <t t-esc="l.get('line_no')"/>
                                                </td>

                                                <td style="border:1px solid black; padding:4px; text-align:center;">
                                                    <t t-esc="l.get('default_code')"/>
                                                </td>

                                                <td style="border:1px solid black; padding:4px; text-align:left;">
                                                    <t t-esc="l.get('description')"/>
                                                </td>

                                                <td style="border:1px solid black; padding:4px; text-align:center;">
                                                    <t t-esc="l.get('uom')"/>
                                                </td>

                                                <td style="border:1px solid black; padding:4px; text-align:center;">
                                                    <t t-esc="'{:,.0f}'.format(l.get('qty') or 0)"/>
                                                </td>

                                                <td style="border:1px solid black; padding:4px; text-align:center;">
                                                    <t t-esc="'{:,.2f}'.format(l.get('rate') or 0)"/>
                                                </td>

                                                <!-- Total column (using your existing computed value) -->
                                                <td style="border:1px solid black; padding:4px; text-align:center;">
                                                    <t t-esc="'{:,.2f}'.format(l.get('total_excl_vat') or 0)"/>
                                                </td>
                                            </tr>
                                        </t>

                                        <!-- ======= SUMMARY ROWS (UPDATED COLSPANS FOR 7 COLUMNS) ======= -->
                                        <tr>
                                            <td colspan="6"
                                                style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <strong>Total (Excl. VAT)</strong>
                                            </td>
                                            <td style="text-align:center; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <t t-esc="'{:,.2f}'.format(totals['total_excl_vat_sum'])"/>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="6"
                                                style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <strong>Discount</strong>
                                            </td>
                                            <td style="text-align:center; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <t t-esc="'{:,.2f}'.format(totals.get('discount_sum', 0.0))"/>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="6"
                                                style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <strong>
                                                    Total VAT @ [<t t-esc="totals.get('vat_percent_display', '0%')"/>]
                                                </strong>
                                            </td>

                                            <td style="text-align:center; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                                <t t-esc="'{:,.2f}'.format(totals['total_vat_sum'])"/>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td colspan="4"
                                                style="font-family: Arial, sans-serif; text-align:left; border:1px solid black; padding:6px;">
                                                <strong>Total in Words</strong>
                                                <span style="padding-left:10px;">
                                                    <t t-esc="totals['amount_in_words']"/>
                                                </span>
                                            </td>

                                            <td colspan="2"
                                                style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black;">
                                                <strong>Total (Incl. VAT)</strong>
                                            </td>

                                            <td style="font-family: Arial, sans-serif; text-align:center; border:1px solid black;">
                                                <strong t-esc="'{:,.2f}'.format(totals['total_incl_vat_sum'])"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Footer -->
    <template id="eme_quotation_footer">
        <div t-attf-class="footer o_company_#{company.id}_layout"
             style="font-size: 16px; padding-top: 10px;">

            <div style="border-top:1px solid #808080; margin-top:15px; margin-bottom:15px;">
                <div style="font-size:16px; padding-top:8px; margin-top:10px;">

                    <!-- Top line: Services -->
                    <div style="text-align:center; padding-top:6px;">
                        Swimming Pools | Water Features | Spas | Aquatic Systems | Mitsubishi Water Tanks
                    </div>

                    <!-- Bottom line: Company + Email + Phone -->
                    <div style="text-align:center; padding-top:4px;">
                        E M E Aquatic Systems L.L.C – S.P.C | info@eme-me.com | +971 (0) 2 677 5022
                    </div>

                </div>
            </div>
        </div>
    </template>

    <!-- Paper format (Portrait / Vertical) -->
    <record id="paperformat_eme_quotation" model="report.paperformat">
        <field name="name">EME: Quotation Paper Formate</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">30</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">18</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_eme_quotation_pdf" model="ir.actions.report">
        <field name="name">EME: Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_eme_custom_invoice.eme_quotation_pdf</field>
        <field name="report_file">visio_eme_custom_invoice.eme_quotation_pdf</field>
        <field name="paperformat_id" ref="visio_eme_custom_invoice.paperformat_eme_quotation"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Quotation_%s' % (object.name)</field>
        <field name="domain">[('state', 'in', ['draft', 'sent'])]</field>
    </record>

</odoo>