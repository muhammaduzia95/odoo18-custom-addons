<odoo>

    <!--  Main Template  -->
    <template id="delivery_note_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <t t-set="is_delivery_note" t-value="True"/>
                <t t-set="company" t-value="o.company_id"/>

                <div class="article"
                     t-att-data-oe-model="o and o._name"
                     t-att-data-oe-id="o and o.id"
                     t-att-data-oe-lang="o and o.env.context.get('lang')">

                    <t t-call="visio_eme_custom_invoice.delivery_note"/>

                    <div id="cpage" class="page" style="padding-top:5mm; padding-bottom:95mm; position:relative;">

                        <!-- ======= INFO BLOCK ======= -->
                        <table style="width:100%; border-color:white; margin-top:15px; font-size:13px;">
                            <tr>
                                <!-- LEFT SIDE: Address below logo -->
                                <td style="font-size:14px; width:60%; vertical-align:top; text-align:left; border-color:white;">
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.street or ''"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-if="o.company_id.zip">
                                            P.O. Box
                                            <t t-esc="o.company_id.zip"/>
                                        </t>
                                        <t t-if="o.company_id.city">
                                            ,
                                            <t t-esc="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.country_id">
                                            ,
                                            <t t-esc="o.company_id.country_id.code"/>
                                        </t>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.phone or ' '"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.email or ' '"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-if="o.company_id.website">
                                            <t t-esc="o.company_id.website"/>
                                        </t>
                                    </p>
                                    <p style="margin:0px 0;" t-if="o.company_id.vat">
                                        TRN:
                                        <t t-esc="o.company_id.vat"/>
                                    </p>
                                </td>

                                <!-- RIGHT SIDE: Both info tables -->
                                <td style="width:40%; vertical-align:top; text-align:left; border-color:white;">
                                    <!-- FIRST TABLE -->
                                    <table style="width:100%; border-color:white;">
                                        <tr>
                                            <td style="width:40%;">D.N. No:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-if="delivery_note_no">
                                                        <t t-esc="delivery_note_no"/>
                                                    </t>
                                                    <t t-if="not delivery_note_no"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:40%;">D.N. Date:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-if="dn_date">
                                                        <t t-esc="dn_date.strftime('%d %b %Y')"/>
                                                    </t>
                                                    <t t-if="not dn_date"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>

                                    <!-- SECOND TABLE -->
                                    <table style="width:100%; border-color:white; margin-top:8px;">
                                        <tr>
                                            <td style="width:40%;">Sales Rep.:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-esc="salesperson or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td style="">Quotation No.:</td>
                                            <td style="">
                                                <strong>
                                                    <t t-esc="quote_no or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td style="">P.O. No.:</td>
                                            <td style="">
                                                <strong>
                                                    <t t-esc="po_number or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="">P.O. Date:</td>
                                            <td style="">
                                                <strong>
                                                    <t t-esc="po_date or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- ======= BILL TO / SHIP TO SECTION ======= -->
                        <table style="width:100%; border:none; border-collapse:collapse; margin-top:15px; font-size:13px;">
                            <tr>
                                <!-- === BILL TO === -->
                                <td style="width:55%; margin-right:30px; vertical-align:top; border:1px solid black; padding:0;">
                                    <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                        <strong>Bill To:</strong>
                                    </div>
                                    <div style="padding:6px;">
                                        <p style="margin:2px 0; margin-bottom: 10px;">
                                            <strong>
                                                <t t-esc="customer_name or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">
                                            <t t-esc="customer_address or '  '"/>
                                        </p>
                                        <p style="margin:2px 0;">Customer Project Name:
                                            <strong>
                                                <t t-esc="project_name or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer TRN:
                                            <strong>
                                                <t t-esc="customer_trn or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer Phone:
                                            <strong>
                                                <t t-esc="customer_phone or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer Email:
                                            <strong>
                                                <t t-esc="customer_email or '  '"/>
                                            </strong>
                                        </p>
                                    </div>
                                </td>
                                <td style="width:5%; border:0px solid white;"></td>

                                <!-- === SHIP TO === -->
                                <td style="width:40%; vertical-align:top; border:1px solid black; padding:0;">
                                    <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                        <strong>Ship To:</strong>
                                    </div>
                                    <div style="padding:6px;">
                                        <p style="margin:2px 0;">
                                            <t t-esc="customer_address"/>
                                        </p>
                                        <p style="margin:2px 0;">Ship Date:
                                            <strong>
                                                <t t-esc="ship_date"/>
                                            </strong>
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ======= MAIN INVOICE LINES TABLE ======= -->
                        <div style="height:550px;">
                            <table style="width:100%; border-collapse:collapse; margin-top:30px; font-size:13px;">
                                <thead>
                                    <tr style="font-family: Arial, sans-serif; background-color:#d9d9d9; text-align:center; height:28px;">
                                        <th style="border:1px solid black; padding:2px 3px; text-align:center; text-transform:capitalize; width:25px;">
                                            <strong>#</strong>
                                        </th>

                                        <th style="width:10%; border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>Item code</strong>
                                        </th>

                                        <th style="width:60%; border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>Description</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>U/M</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>Qty</strong>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="line_data" t-as="l">
                                        <tr style="page-break-inside: avoid;">
                                            <td style="border:1px solid black;  text-align:center; padding:4px;">
                                                <t t-esc="l.get('line_no')"/>
                                            </td>
                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="l.get('default_code')"/>
                                            </td>
                                            <td style="border:1px solid black; width:30%; padding:4px; text-align:left;">
                                                <t t-esc="l.get('description')"/>
                                            </td>

                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="l.get('uom')"/>
                                            </td>
                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="'{:,.0f}'.format(l.get('qty') or 0)"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                    </div>


                    <!-- SIG (inside page, absolute => will land on LAST page only) -->
                    <div id="sig" class="sig d-flex justify-content-between"
                         style="margin:0; font-size:16px; page-break-inside:avoid;">
                        <div>
                            <strong style="font-family: Arial, sans-serif;">Prepared By:</strong>
                            <p style="white-space: nowrap; margin:0">
                                <t t-esc="salesperson"/>
                            </p>
                            <p style="white-space: nowrap; margin:0">
                                <t t-esc="salesperson_dept"/>
                            </p>
                            <p style="white-space: nowrap; margin:0">
                                <t t-esc="salesperson_desig"/>
                            </p>
                        </div>
                        <div>
                            <strong style="font-family: Arial, sans-serif;">Verified By:</strong>
                        </div>
                        <div>
                            <strong style="font-family: Arial, sans-serif;">Approved By:</strong>
                        </div>
                        <div>
                            <strong style="font-family: Arial, sans-serif;">Received By:</strong>
                        </div>
                    </div>

                </div>

                <!-- Footer -->
                <t t-call="visio_eme_custom_invoice.eme_delivery_note_footer"/>


            </t>
        </t>
    </template>


