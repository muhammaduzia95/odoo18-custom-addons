    <!-- Paper format (Portrait / Vertical) -->
    <record id="paperformat_tax_debit_note" model="report.paperformat">
        <field name="name">EME: Tax Debit Note Paper Formate</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">60</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">18</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_tax_debit_note" model="ir.actions.report">
        <field name="name">EME: Tax Debit Note</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_eme_custom_invoice.tax_debit_note_pdf</field>
        <field name="report_file">visio_eme_custom_invoice.tax_debit_note_pdf</field>
        <field name="paperformat_id" ref="visio_eme_custom_invoice.paperformat_tax_debit_note"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Tax_Debit_Note_%s' % (object.name)</field>
        <!--        <field name="domain">[('move_type', '=', 'out_invoice')]</field>-->

        <field name="domain">[('move_type', '=', 'out_refund'), ('reversed_entry_id', '!=', True)]</field>


    </record>

</odoo>