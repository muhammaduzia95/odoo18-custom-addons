<odoo>

    <template id="tax_debit_note_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <t t-set="is_tax_debit" t-value="True"/>
                    <div class="page">

                        <!-- ======= INFO BLOCK ======= -->
                        <table style="width:100%; border-color:white; margin-top:15px; font-size:13px;">
                            <tr>
                                <!-- LEFT SIDE: Address below logo -->
                                <td style="font-size:14px; width:60%; vertical-align:top; text-align:left; border-color:white;">
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.street or ''"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-if="o.company_id.zip">
                                            P.O. Box
                                            <t t-esc="o.company_id.zip"/>
                                        </t>
                                        <t t-if="o.company_id.city">
                                            ,
                                            <t t-esc="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.country_id">
                                            ,
                                            <t t-esc="o.company_id.country_id.code"/>
                                        </t>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.phone or ' '"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-esc="o.company_id.email or ' '"/>
                                    </p>
                                    <p style="margin:0px 0;">
                                        <t t-if="o.company_id.website">
                                            <t t-esc="o.company_id.website"/>
                                        </t>
                                    </p>
                                    <p style="margin:0px 0;" t-if="o.company_id.vat">
                                        TRN:
                                        <t t-esc="o.company_id.vat"/>
                                    </p>
                                </td>

                                <!-- RIGHT SIDE: Both info tables -->
                                <td style="width:40%; vertical-align:top; text-align:left; border-color:white;">
                                    <!-- FIRST TABLE -->
                                    <table style="width:100%; border-color:white;">
                                        <tr>
                                            <td style="width:40%;">T.D.N. No:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-if="o.name">
                                                        <t t-esc="o.name"/>
                                                    </t>
                                                    <t t-if="not name"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:40%;">T.D.N. Date:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-if="pi_date">
                                                        <t t-esc="pi_date.strftime('%d %b %Y')"/>
                                                    </t>
                                                    <t t-if="not pi_date"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="width:40%;">EME G.R.N. No:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-if="grn_no">
                                                        <t t-esc="grn_no"/>
                                                    </t>
                                                    <t t-if="not grn_no"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="">Payment Terms:</td>
                                            <td style="">
                                                <strong>
                                                    <t t-esc="payment_terms or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>

                                    <!-- SECOND TABLE -->
                                    <table style="width:100%; border-color:white; margin-top:8px;">
                                        <tr>
                                            <td style="width:40%;">Supplier D.N. No.:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-esc="delivery_note_no or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td style="width:40%;">EME P.O. No.:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-esc="po_number or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>

                                        <tr>
                                            <td style="width:40%;">Project Code:</td>
                                            <td style="width:60%;">
                                                <strong>
                                                    <t t-esc="pcode or ' '"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- ======= BILL TO / SHIP TO SECTION ======= -->
                        <table style="width:100%; border:none; border-collapse:collapse; margin-top:15px; font-size:13px;">
                            <tr>
                                <!-- === BILL TO === -->
                                <td style="width:55%; margin-right:30px; vertical-align:top; border:1px solid black; padding:0;">
                                    <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                        <strong>Bill To:</strong>
                                    </div>
                                    <div style="padding:6px;">
                                        <p style="margin:2px 0; margin-bottom: 10px;">
                                            <strong>
                                                <t t-esc="customer_name or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">
                                            <t t-esc="customer_address or '  '"/>
                                        </p>
                                        <p style="margin:2px 0;">Customer Project Name:
                                            <strong>
                                                <t t-esc="project_name or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer TRN:
                                            <strong>
                                                <t t-esc="customer_trn or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer Phone:
                                            <strong>
                                                <t t-esc="customer_phone or '  '"/>
                                            </strong>
                                        </p>
                                        <p style="margin:2px 0;">Customer Email:
                                            <strong>
                                                <t t-esc="customer_email or '  '"/>
                                            </strong>
                                        </p>
                                    </div>
                                </td>
                                <td style="width:5%; border:0px solid white;">
                                </td>

                                <!-- === SHIP TO === -->
                                <td style="width:40%; vertical-align:top; border:1px solid black; padding:0;">
                                    <div style="background-color:#d9d9d9; padding:4px 6px; font-family: Arial, sans-serif;">
                                        <strong>Ship To:</strong>
                                    </div>
                                    <div style="padding:6px;">
                                        <p style="margin:2px 0;">
                                            <!--                                <t t-esc="ship_to_address"/>-->
                                            <t t-esc="customer_address"/>
                                        </p>
                                        <p style="margin:2px 0;">Ship Date:
                                            <strong>
                                                <t t-esc="ship_date"/>
                                            </strong>
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- ======= MAIN INVOICE LINES TABLE ======= -->
                        <div style="height:550px;">
                            <table style="width:100%; border-collapse:collapse; margin-top:30px; font-size:13px;">
                                <thead>
                                    <tr style="font-family: Arial, sans-serif; background-color:#d9d9d9; text-align:center; height:28px;">
                                        <th style="border:1px solid black; padding:2px 3px; text-align:center; text-transform:capitalize; width:25px;">
                                            <strong>#</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>Item code</strong>
                                        </th>

                                        <th style="width:30%; border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>Description</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>U/M</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:center; text-transform:capitalize;">
                                            <strong>Qty</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>Unit price</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>Total<br/>(Excl. VAT)
                                            </strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>VAT<br/>%
                                            </strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>VAT Amount</strong>
                                        </th>

                                        <th style="border:1px solid black; padding:2px 6px; text-align:left; text-transform:capitalize;">
                                            <strong>Total<br/>(Incl. VAT)
                                            </strong>
                                        </th>

                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="line_data" t-as="l">
                                        <tr style="page-break-inside: avoid;">
                                            <td style="border:1px solid black;  text-align:center; padding:4px;">
                                                <t t-esc="l.get('line_no')"/>
                                            </td>
                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="l.get('default_code')"/>
                                            </td>
                                            <td style="border:1px solid black; width:30%; padding:4px; text-align:left;">
                                                <t t-esc="l.get('description')"/>
                                            </td>

                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="l.get('uom')"/>
                                            </td>
                                            <td style="border:1px solid black;  padding:4px; text-align:center;">
                                                <t t-esc="'{:,.0f}'.format(l.get('qty') or 0)"/>
                                            </td>

                                            <td style="border:1px solid black; padding:4px; text-align:center;">
                                                <t t-esc="'{:,.2f}'.format(l.get('rate') or 0)"/>
                                            </td>
                                            <td style="border:1px solid black; padding:4px; text-align:center;">
                                                <t t-esc="'{:,.2f}'.format(l.get('total_excl_vat') or 0)"/>
                                            </td>
                                            <td style="border:1px solid black; padding:4px; text-align:center;">
                                                <t t-esc="l.get('vat_percent_display') or '-'"/>
                                            </td>
                                            <td style="border:1px solid black; padding:4px; text-align:center;">
                                                <t t-esc="'{:,.2f}'.format(l.get('vat_amount') or 0)"/>
                                            </td>
                                            <td style="border:1px solid black; padding:4px; text-align:center;">
                                                <t t-esc="'{:,.2f}'.format(l.get('total_incl_vat') or 0)"/>
                                            </td>
                                        </tr>
                                    </t>

                                    <!-- ======= SUMMARY ROWS ======= -->
                                    <tr>
                                        <td colspan="9"
                                            style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                            <strong>Total (Excl. VAT)</strong>
                                        </td>
                                        <td style="text-align:center; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                            <t t-esc="'{:,.2f}'.format(totals['total_excl_vat_sum'])"/>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td colspan="9"
                                            style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                            <strong>VAT Total</strong>
                                        </td>
                                        <td style="text-align:center; border:1px solid black; padding-top:6px; padding-bottom:6px;">
                                            <t t-esc="'{:,.2f}'.format(totals['total_vat_sum'])"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="7"
                                            style="font-family: Arial, sans-serif; text-align:left; border:1px solid black; padding:6px;">
                                            <strong>Total in Words</strong>
                                            <span style="padding-left:10px;">
                                                <t t-esc="totals['amount_in_words']"/>
                                            </span>
                                        </td>
                                        <td colspan="2"
                                            style="font-family: Arial, sans-serif; text-align:right; padding-right:25px; border:1px solid black;">
                                            <strong>Total (Incl. VAT)</strong>
                                        </td>
                                        <td style="font-family: Arial, sans-serif; text-align:center; border:1px solid black;">
                                            <strong t-esc="'{:,.2f}'.format(totals['total_incl_vat_sum'])"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Footer -->
    <template id="eme_tax_debit_note_footer">
        <div t-attf-class="footer o_company_#{company.id}_layout"
             style="font-size: 16px; padding-top: 10px;">
            <div class="d-flex justify-content-between" style="margin-top:20px;">
