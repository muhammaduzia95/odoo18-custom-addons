    <template id="eme_external_layout_standard" inherit_id="web.external_layout_standard">
        <xpath expr="//div[contains(@t-attf-class,'header')]" position="replace">

            <!-- Cover page must win FIRST -->
            <t t-if="is_cover_page">
                <t t-call="visio_eme_custom_invoice.cover_header"/>
            </t>
            <t t-elif="is_tax_credit">
                <t t-call="visio_eme_custom_invoice.tax_credit_note"/>
            </t>
            <t t-elif="is_tax_debit">
                <t t-call="visio_eme_custom_invoice.tax_debit_note"/>
            </t>
            <t t-elif="is_issue_note">
                <t t-call="visio_eme_custom_invoice.material_issue_note"/>
            </t>
            <t t-elif="is_delivery_note">
                <t t-call="visio_eme_custom_invoice.delivery_note"/>
            </t>
            <t t-elif="is_supplier_invoice">
                <t t-call="visio_eme_custom_invoice.supplier_invoice_header"/>
            </t>
            <t t-elif="is_goods_receipt">
                <t t-call="visio_eme_custom_invoice.goods_receipt_note_header"/>
            </t>
            <t t-elif="is_purchase_order">
                <t t-call="visio_eme_custom_invoice.purchase_order_header"/>
            </t>
            <t t-elif="is_rfq">
                <t t-call="visio_eme_custom_invoice.rfq_header"/>
            </t>
            <t t-elif="is_material_request">
                <t t-call="visio_eme_custom_invoice.material_request_header"/>
            </t>
            <t t-elif="is_tax_invoice">
                <t t-call="visio_eme_custom_invoice.tax_invoice_header"/>
            </t>
            <t t-elif="is_material_return">
                <t t-call="visio_eme_custom_invoice.material_return_note_header"/>
            </t>
            <t t-elif="is_quotation">
                <t t-call="visio_eme_custom_invoice.quotation_header"/>
            </t>
            <t t-else="">
                <t t-call="visio_eme_custom_invoice.performa_invoice_service"/>
            </t>

        </xpath>
    </template>

    <!--  Replacing the original headers  -->
