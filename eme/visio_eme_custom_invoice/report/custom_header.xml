<odoo>

    <!--  PROFORMA INVOICE  -->
    <template id="performa_invoice_service">
        <div t-attf-class="header o_company_#{company.id}_layout"
             style="padding-bottom: 10px; padding-left:0px;"
             class="border-top-0">
            <div class="d-flex justify-content-between"
                 style="display: flex; padding:0px; justify-content: space-between; align-items: center;">
                <img t-if="company.logo" style="width:180px; height:130px;" class="o_company_logo_small"
                     t-att-src="image_data_uri(company.logo)"
                     alt="Logo"/>

                <h2 style="margin:0; font-size:30px; font-family: Arial, sans-serif; text-align: right; color: black;white-space: nowrap;">
                    <strong>PROFORMA INVOICE</strong>
                </h2>

            </div>
        </div>
    </template>

