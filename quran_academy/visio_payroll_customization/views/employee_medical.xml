<odoo>

    <!--    search view-->
    <record id="view_employee_medical_search" model="ir.ui.view">
        <field name="name">Employee Medical/Loan Search</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Month" name="filter_by_month" date="date_from"/>
                <separator/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting" name="filter_waiting" domain="[('state', '=', 'verify')]"/>
                <filter string="Rejected" name="filter_cancel" domain="[('state', '=', 'cancel')]"/>
                <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                <filter string="Start Date" name="group_by_start_date" context="{'group_by': 'date_from'}"/>
            </search>
        </field>
    </record>

    <record id="view_employee_medical_tree" model="ir.ui.view">
        <field name="name">hr.employee.medical.tree</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <list string="Employee Medical/Loan" create="false" expand="1">
                <field name="employee_id" width="25%"/>
                <field name="medical" width="25%"/>
                <field name="loan_recovery" width="25%"/>
                <field name="date_from" width="25%"/>
                <field name="date_to" width="25%"/>
            </list>
        </field>
    </record>

    <!-- action for employee medical -->
    <record id="action_employee_medical" model="ir.actions.act_window">
        <field name="name">Employee Medical/Loan</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_id" ref="view_employee_medical_tree"/>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_employee_medical_search"/>
        <field name="context">{'search_default_group_by_employee': 1 , 'search_default_group_by_start_date': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Medical Record Exists.
            </p>
        </field>
    </record>

    <!--Employee Medical menu -->
    <menuitem
            id="menu_employee_medical"
            name="Employee Medical/Loan"
            sequence="20"
            parent="om_hr_payroll.menu_payroll_employee"
            action="action_employee_medical"
    />

    <!--    &lt;!&ndash; Inherit and change the parent of Employee Payslips &ndash;&gt;-->
    <!--    <record id="om_hr_payroll.menu_department_tree" model="ir.ui.menu">-->
    <!--        <field name="parent_id" ref="menu_employee_medical_payslip_main"/>-->
    <!--        <field name="name">Employee Payslips</field>-->
    <!--    </record>-->

    <record id="action_view_hr_payslip_form" model="ir.actions.act_window">
        <field name="name">Employee Payslips</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="om_hr_payroll.view_hr_payslip_tree"/>
        <field name="search_view_id" ref="om_hr_payroll.view_hr_payslip_filter"/>
    </record>

    <menuitem
            id="menu_employee_medical_payslip_main"
            name="Employee Payslips"
            sequence="5"
            parent="om_hr_payroll.menu_hr_payroll_root"
            action="action_view_hr_payslip_form"
    />

    <menuitem id="om_hr_payroll.menu_department_tree"
              name="Employee Payslips"
              action="action_view_hr_payslip_form"
              parent="menu_employee_medical_payslip_main"
              groups="om_hr_payroll.group_hr_payroll_user"/>



</odoo>