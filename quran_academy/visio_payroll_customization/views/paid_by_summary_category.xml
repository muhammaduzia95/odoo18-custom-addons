<odoo>
    <!--    list view paid by summary-->
    <record id="view_paid_by_summary_category_tree" model="ir.ui.view">
        <field name="name">paid.by.summary.category.list</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <list string="Paid By Summary Category" create="false" expand="1">
                <field name="currency_id" column_invisible="True"/>
                <field name="first_child_dep"/>
                <field name="net_payable" sum="total"/>
            </list>
        </field>
    </record>

    <!--    search view for paid by summary-->
    <record id="view_paid_by_summary_category_search" model="ir.ui.view">
        <field name="name">Paid by Summary Category Search</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Month" name="filter_by_month" date="date_from"/>
                <separator/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting" name="filter_waiting" domain="[('state', '=', 'verify')]"/>
                <filter string="Rejected" name="filter_cancel" domain="[('state', '=', 'cancel')]"/>
                <filter string="First Child Department" name="group_by_first_child_dep"
                        context="{'group_by': 'first_child_dep'}"/>
                <filter string="Paid By" name="group_by_paid_by" context="{'group_by': 'paid_by'}"/>
            </search>
        </field>
    </record>

    <!--   action for paid by summary menu-->
    <record id="action_paid_by_summary_category" model="ir.actions.act_window">
        <field name="name">Paid By Summary Category</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_id" ref="view_paid_by_summary_category_tree"/>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_paid_by_summary_category_search"/>
        <field name="context">{'search_default_group_by_first_child_dep': 1 , 'search_default_group_by_paid_by': 1 ,
            'search_default_filter_by_month': 1, 'search_default_filter_done': 1 , 'export_filename': 'Paid By Summary Category'}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Paid by Records.
            </p>
        </field>
    </record>

    <!--    paid by summary menu-->
    <menuitem
            id="menu_paid_by_summary_category"
            name="Paid By Summary Category"
            sequence="30"
            parent="menu_payroll_reporting"
            action="action_paid_by_summary_category"
    />
</odoo>