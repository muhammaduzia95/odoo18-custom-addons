<odoo>
    <record id="view_pay_receiving_cash_list" model="ir.ui.view">
        <field name="name">pay.receiving.cash.list</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <list string="Pay Receiving Cash List" create="false" class="equal-spaced-tree" expand="1">
                <field name="currency_id" column_invisible="True"/>
                <field name="paid_by" column_invisible="True" expand="1"/>
                <field name="first_child_dep" column_invisible="True"/>
                <field name="worker_code"/>
                <field name="employee_id"/>
                <field name="net_payable" sum="total"/>
            </list>
        </field>
    </record>

    <record id="view_pay_receiving_cash_search" model="ir.ui.view">
        <field name="name">Pay Receiving Cash Search</field>
        <field name="model">hr.payslip</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Month" name="filter_by_month" date="date_from"/>
                <separator/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting" name="filter_waiting" domain="[('state', '=', 'verify')]"/>
                <filter string="Rejected" name="filter_cancel" domain="[('state', '=', 'cancel')]"/>
                <filter string="First Child Department" name="group_by_first_child_department"
                        context="{'group_by': 'first_child_dep'}"/>
                <filter string="Paid By" name="group_by_paid_by"
                        context="{'group_by': 'paid_by'}"/>
            </search>
        </field>
    </record>

    <record id="action_pay_receiving_cash" model="ir.actions.act_window">
        <field name="name">Pay Receiving Cash List</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_id" ref="view_pay_receiving_cash_list"/>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_pay_receiving_cash_search"/>
        <field name="context">{ 'search_default_group_by_first_child_department': 1 , 'search_default_group_by_paid_by':
            1 'search_default_filter_by_month': 1 , 'search_default_filter_done': 1, 'export_filename': 'Pay Receiving
            Cash List'}
        </field>
        <field name="domain">[('paid_by', '=', 'cash')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Records.
            </p>
        </field>
    </record>

    <menuitem
            id="menu_pay_receiving_cash"
            name="Pay Receiving Cash List"
            sequence="100"
            parent="menu_payroll_reporting"
            action="action_pay_receiving_cash"
    />
</odoo>