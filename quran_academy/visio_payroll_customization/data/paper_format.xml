<odoo>
    <record id="paperformat_legal_landscape" model="report.paperformat">
        <field name="name">Landscape Legal</field>
        <field name="default" eval="True"/>
        <field name="format">Legal</field>  <!-- Changed from A4 to Legal -->
        <field name="orientation">Landscape</field>
        <field name="dpi">110</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
    </record>


    <record id="paperformat_landscape" model="report.paperformat">
        <field name="name">Landscape A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="dpi">110</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
    </record>

    <record id="paperformat_portrait" model="report.paperformat">
        <field name="name">Portrait A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="dpi">110</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">10</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
    </record>

</odoo>
