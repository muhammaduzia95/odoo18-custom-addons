<!--quran_academy\visio_payroll_customization\wizard\import_exel_wizard.xml-->
<odoo>
    <record id="view_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">excel.import.wizard.form</field>
        <field name="model">excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel File">
                <group>
                    <group>
                        <field name="file" widget="binary" filename="file_name"/>
                    </group>
                    <group>
                        <field name="month"/>
                        <field name="download_sample_url" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <!--<button string="Import and Update" type="object" name="import_excel_file" class="btn-primary"/>-->

                    <button string="Import and Update"
                            type="object"
                            name="import_excel_file"
                            class="btn-primary"
                            confirm="Warning ‑ Are you sure? These changes are hard to undo."/>


                    <button type="object" string="Download Sample" name="action_download_sample_url"
                            class="btn btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_excel" model="ir.actions.act_window">
        <field name="name">Import Excel</field>
        <field name="res_model">excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
