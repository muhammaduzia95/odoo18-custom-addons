        <field name="name">Payroll Sheet</field>
        <field name="model">pdf.reports.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_payroll_customization.payroll_sheet_template</field>
        <field name="report_file">visio_payroll_customization.payroll_sheet_template</field>
        <field name="paperformat_id" ref="visio_payroll_customization.paperformat_legal_landscape"/>
    </record>

