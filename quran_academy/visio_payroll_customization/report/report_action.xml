<odoo>
    <!--    yearly salary report action-->
    <record id="worker_payslip_report_action" model="ir.actions.report">
        <field name="name">Yearly Salary Report</field>
        <field name="model">yearly.salary.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_payroll_customization.yearly_salary_template</field>
        <field name="print_report_name">'Yearly_Salary_Report_' + object.worker_code</field>
        <field name="paperformat_id" ref="visio_payroll_customization.paperformat_landscape"/>
    </record>

    <!--    Pay receiving bank list-->
    <record id="pay_receiving_list_report_action" model="ir.actions.report">
        <field name="name">Pay Receiving Bank List</field>
