<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="eobi_anjuman_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <style type="text/css">
                    /* Urdu font definition */
                    @font-face {
                    font-family: "Jameel";
                    src: url('/visio_payroll_customization/static/font/jameel.ttf') format("woff");
                    font-weight: normal;
                    font-style: normal;
                    }
                    body {
                    font-family: "Jameel";
                    }
                    th, td {
                    font-size: 14px;
                    padding: 4px;
                    border-color: white;
                    }
                    th {
                    border-bottom: 2px solid black;
                    font-weight: bold;
                    }
                    table {
                    width: 100%;
                    margin-bottom: 20px;
                    border-collapse: collapse;
                    }
                </style>

                <div class="page" style="font-family: 'Times New Roman', serif;">
                    <!-- Header -->
                    <div style="text-align: center; margin-bottom: 20px;">

                        <table style="width:100%; border-color:white; background-color: white;">
                            <tr style=" border-color:white;">
                                <!-- left: logo -->
                                <td style="width:60px; background-color: white;">
                                    <img t-att-src="'/visio_payroll_customization/static/img/bg.png'"
                                         style="height:100px; width:75px;" alt="Logo"/>
                                </td>

                                <!-- center: title -->
                                <td style="text-align:center; background-color: white;">
                                    <h2 style="margin:0;">
                                        Contribution Bill for the Month of
                                        <t t-esc="month"/>
                                    </h2>
                                </td>

                                <!-- right: blank spacer same width as logo -->
                                <td style="width:60px; background-color: white;"></td>
                            </tr>
                        </table>


                        <!--                        <h2>-->
                        <!--                            Contribution Bill for the Month of-->
                        <!--                            <t t-esc="month"/>-->
                        <!--                        </h2>-->
                        <p style="margin: 5px 0;">
                            Employees of :
                            <strong>Markazi Anjuman Khuddam-ul-Quran, Lahore</strong>
                        </p>
                        <p style="margin: 0;">
                            Registration No.
                            <strong>BIB00184</strong>
                        </p>
                    </div>

                    <!-- Table -->
                    <table>
                        <thead>
                            <tr>
                                <th style="">S#</th>
                                <th style="">Code</th>
                                <th style="">EOBI#</th>
                                <th style="text-align: left;">Name</th>
                                <th>Designation</th>
                                <th>Employer's Count</th>
                                <th>EOBI Employee</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="s" t-value="1"/>
                            <t t-foreach="docs" t-as="payslip">
                                <tr>
                                    <td style="text-align: right;">
                                        <t t-esc="s"/>
                                    </td>
                                    <td style="text-align: right;">
                                        <t t-esc="payslip.worker_code"/>
                                    </td>
                                    <td>
                                        <t t-esc="payslip.employee_id.eobi_num or ''"/>
                                    </td>
                                    <td>
                                        <t t-esc="payslip.employee_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="payslip.employee_job_title"/>
                                    </td>
                                    <td style="text-align: right;">
                                        <t t-esc="payslip.emp_eobi"/>
                                    </td>
                                    <td style="text-align: right;">
                                        <t t-esc="payslip.eobi_worker"/>
                                    </td>
                                </tr>
                                <t t-set="s" t-value="s + 1"/>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Summary Section -->
                <t t-set="total_workers" t-value="len(docs)"/>
                <t t-set="total_emp_eobi" t-value="sum(p.emp_eobi    for p in docs)"/>
                <t t-set="total_eobi_worker" t-value="sum(p.eobi_worker for p in docs)"/>
                <t t-set="grand_total" t-value="total_emp_eobi + total_eobi_worker"/>

                <!-- pretty two‑column block -->
                <div style="width: 60%; margin: 40px auto 0; font-size: 18px;">

                    <p style="margin: 4px 0;">
                        <span style="font-weight:bold; display:inline-block; width:60%;">No of worker</span>
                        <span style="">
                            <t t-esc="total_workers"/>
                        </span>
                    </p>

                    <p style="margin: 4px 0;">
                        <span style="font-weight:bold; display:inline-block; width:60%;">EOBI Employer's Contribution:
                        </span>
                        <span style="">
                            <t t-esc="total_emp_eobi"/>
                        </span>
                    </p>

                    <p style="margin: 4px 0;">
                        <span style="font-weight:bold; display:inline-block; width:60%;">EOBI Employee Contribution:
                        </span>
                        <span style="">
                            <t t-esc="total_eobi_worker"/>
                        </span>
                    </p>

                    <!-- underline -->
                    <div style="width:40%; margin:8px 0 6px auto; border-top:1px solid #000;"></div>

                    <p style="margin: 4px 0;">
                        <span style="font-weight:bold; display:inline-block; width:60%;">Grand Total:</span>
                        <span style="">
                            <t t-esc="grand_total"/>
                        </span>
                    </p>
                </div>


                <!--                &lt;!&ndash; Footer &ndash;&gt;-->
                <!--                <div class="footer" style="text-align:right; font-size: 12px;">-->
                <!--                    Page-->
                <!--                    <strong class="page"/>-->
                <!--                    of-->
                <!--                    <strong class="topage"/>-->
                <!--                </div>-->
            </t>
        </t>
    </template>
</odoo>
