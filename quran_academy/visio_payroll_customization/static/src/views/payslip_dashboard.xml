                <!--                    <div class="p-2 bg-light text-center rounded shadow-sm w-100 d-flex flex-column align-items-center justify-content-center">-->
                <!--                        <h5 class="">Total Payslips</h5>-->
                <!--                        <h4 t-out="payslipData['total_payslips']"/>-->
                <!--                    </div>-->
                <!--                    <div class="p-2 bg-light text-center rounded shadow-sm w-100 d-flex flex-column align-items-center justify-content-center">-->
                <!--                        <h5 class="">Draft Payslips</h5>-->
                <!--                        <h4 t-out="payslipData['draft_payslips']"/>-->
                <!--                    </div>-->
                <!--                    <div class="p-2 bg-light text-center rounded shadow-sm w-100 d-flex flex-column align-items-center justify-content-center">-->
                <!--                        <h5 class="">Confirmed Payslips</h5>-->
                <!--                        <h4 t-out="payslipData['confirmed_payslips']"/>-->
                <!--                    </div>-->
                <!--                </div>-->
            </div>
        </div>
    </t>
</templates>
