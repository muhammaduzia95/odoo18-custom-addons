<!--quran_academy\visio_contact_extension_qa\wizard\lables_list_wizard_view.xml-->
<odoo>

    <!-- Wizard View -->
    <record id="view_lables_list_wizard_form" model="ir.ui.view">
        <field name="name">lables.list.wizard.form</field>
        <field name="model">lables.list.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Lables/List Report">
                <group>
                    <field name="print_type" widget="radio" options="{'horizontal': True}"/>
                </group>
                <group>
                    <group>
                        <field name="qa_gender"/>
                    </group>
                    <group>
                        <field name="qa_type_contact"/>
                    </group>
                </group>

                <footer>
                    <button name="action_generate_report"
                            type="object"
                            string="Generate PDF"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_lables_list_wizard" model="ir.actions.act_window">
        <field name="name">Generate Lables/List</field>
        <field name="res_model">lables.list.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_lables_list_wizard"
              name="Generate Lables/List"
              parent="visio_contact_extension_qa.menu_lables_root"
              action="visio_contact_extension_qa.action_lables_list_wizard"
              sequence="20"
              groups="base.group_user"/>

</odoo>
