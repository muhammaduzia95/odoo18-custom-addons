<!--quran_academy\visio_contact_extension_qa\wizard\elections_wizard_view.xml-->
<odoo>
    <record id="view_elections_wizard_form" model="ir.ui.view">
        <field name="name">elections.wizard.form</field>
        <field name="model">elections.wizard</field>
        <field name="arch" type="xml">
            <form string="Elections Filters">

                <group>
                    <group>
                        <field name="member_selection"/>
                        <field name="trans_upto_date"/>
                    </group>
                    <group>
                        <field name="mem_date_candidate"/>
                        <field name="mem_date_voters"/>
                    </group>
                </group>
                <group>
                    <field name="report_type" widget="radio" nolabel="1" options="{'horizontal': True}"/>
                </group>
                <footer>
                    <button name="action_list_candidates" string="List Candidates" type="object" class="btn-secondary"/>
                    <button name="action_list_voters" string="List Voters" type="object" class="btn-secondary"/>
                    <button name="action_label_voters" string="Lable Voters PDF" type="object" class="btn-secondary"/>
                    <button name="action_label_candidates" string="Lable Candidates PDF" type="object" class="btn-secondary"/>

                    <button string="Cancel" class="btn-primary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_elections_wizard" model="ir.actions.act_window">
        <field name="name">Elections</field>
        <field name="res_model">elections.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
