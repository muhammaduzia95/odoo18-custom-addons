<!--\carib_island_trading\visio_cit_sale_customization\views\product_pricelist_view.xml-->
<odoo>
    <record id="view_product_pricelist_form_inherit_user" model="ir.ui.view">
        <field name="name">product.pricelist.form.inherit.user</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">

            <!-- Add under Pricelist form, before currency -->
            <xpath expr="//field[@name='currency_id']" position="before">
                <field name="assigned_user_id"
                       required="1" options="{'no_create': True, 'no_create_edit': True}"/>
            </xpath>

        </field>
    </record>
</odoo>
