<!--carib_island_trading\visio_cit_sale_customization\views\account_move_view.xml-->
<odoo>
    <record id="view_move_form_inherit_documents" model="ir.ui.view">
        <field name="name">account.move.form.documents</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Documents">
                    <group string="Attachments">
                        <field name="attachment_ids_in" widget="many2many_binary" nolabel="1"/>
                    </group>
                </page>
            </xpath>


            <xpath expr="//field[@name='invoice_line_ids']//field[@name='tax_ids']" position="before">
                <field name="markup_percent_line_inv" readonly="1"/>
                <field name="margin_percent_line_inv" readonly="1"/>
            </xpath>


        </field>
    </record>
</odoo>
