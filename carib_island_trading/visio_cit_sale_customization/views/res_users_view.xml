<!--carib_island_trading\visio_cit_sale_customization\views\res_users_view.xml-->
<odoo>
    <record id="view_users_form_inherit_salesperson" model="ir.ui.view">
        <field name="name">res.users.form.inherit.salesperson</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

             <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Salesperson">
                    <field name="is_salesperson"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
