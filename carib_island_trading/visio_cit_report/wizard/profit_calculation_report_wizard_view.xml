<odoo>

    <!-- Wizard Form View -->
    <record id="view_profit_report_wizard_form" model="ir.ui.view">
        <field name="name">profit.report.wizard.form</field>
        <field name="model">profit.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Profit Calculation Report">
                <group>
                    <group>
                        <field name="sale_order_id" options="{'no_create': True}" required="1"/>
                        <field name="commission_amount" required="1"/>
                    </group>

                    <group>
                        <field name="sales_rep_id" required="1" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_excel"
                            type="object"
                            string="Export Excel"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_profit_report_wizard" model="ir.actions.act_window">
        <field name="name">Profit Margin Report</field>
        <field name="res_model">profit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu: Sales → Reporting → Profit Calculation -->
    <menuitem id="menu_profit_calculation_report"
              name="Profit Margin Report"
              parent="sale.menu_sale_report"
              action="action_profit_report_wizard"
              sequence="50"/>
</odoo>
