<odoo>

    <!-- Server action that calls the Python generator -->
    <record id="action_profit_calculation_report" model="ir.actions.server">
        <field name="name">Profit Calculation Report</field>
        <!-- model_id can be anything; not really used -->
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">
            action = env['profit.calculation.report'].action_generate_excel()
        </field>
    </record>

    <!-- Menu under Sales ▸ Reporting -->
    <menuitem id="menu_profit_calculation_report"
              name="Profit Calculation"
              parent="sale.menu_sale_report"
              action="action_profit_calculation_report"
              sequence="50"/>
</odoo>
