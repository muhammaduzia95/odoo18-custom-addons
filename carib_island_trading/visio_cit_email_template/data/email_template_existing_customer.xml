<!--carib_island_trading\visio_cit_email_templates\data\email_template_new_customer.xml-->
<odoo>
    <data noupdate="0">

        <record id="email_template_tanisha_existing_customer" model="mail.template">
            <field name="name">Sales: Formal Order to Tanisha (Existing Customer)</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Formal Order - {{ object.name or 'No Ref' }}</field>
            <field name="email_from">{{ (object.company_id.email_formatted) }}
            </field>
            <field name="email_to"></field>
            <field name="description">Used to send a formal order to Tanisha for existing customers.</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="font-size: 13px; margin: 0; padding: 0;">
                        Dear Tanisha,
                        <br/>
                        <br/>
                        Please find attached the formal order:
                        <ul style="margin: 0; padding-left: 16px;">
                            <li>
                                <strong>Payment Terms:</strong>
                                Net 30
                            </li>
                            <li>
                                <strong>Freight Terms:</strong>
                                FOB Origin
                            </li>
                        </ul>
                        <br/>
                        Regards,
                        <br/>
                        Sales Team
                    </p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
