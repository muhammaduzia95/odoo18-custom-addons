<?xml version="1.0" encoding="UTF-8"?>
<!--\carib_island_trading\visio_cit_purchase_request\views\sub_shipping_view.xml-->
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_sub_shipping_method_tree" model="ir.ui.view">
            <field name="name">sub.shipping.method.tree</field>
            <field name="model">sub.shipping</field>
            <field name="arch" type="xml">
                <list>
                    <field name="shipping_method_id"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_sub_shipping_method" model="ir.actions.act_window">
            <field name="name">Sub Shipping Methods</field>
            <field name="res_model">sub.shipping</field>
            <field name="view_mode">list</field>
        </record>

        <!-- Menu (under Purchase > Configuration) -->
        <menuitem id="menu_sub_shipping_method"
                  name="Sub Shipping Methods"
                  parent="visio_cit_purchase_request.root_shipping_method"
                  action="action_sub_shipping_method"/>
    </data>
</odoo>


