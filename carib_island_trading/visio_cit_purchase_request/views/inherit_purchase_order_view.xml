<!--\carib_island_trading\visio_cit_purchase_request\views\inherit_purchase_order_view.xml-->
<odoo>
    <record id="purchase_order_form_logistics" model="ir.ui.view">
        <field name="name">purchase.order.form.logistics</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page name="logistics" string="Logistics"  invisible="0">
                    <field name="logistics_ids" mode="list,form">
                        <list editable="bottom">
                            <field name="shipping_method_id"/>
                            <field name="sub_shipping_id" domain="[('shipping_method_id','=',shipping_method_id)]"
                                   options="{'no_create': True, 'no_open': True}"/>

                            <field name="company_email_cit" optional="hide"/>
                            <field name="origin_custom_clearance" optional="hide"/>
                            <field name="pickup_address_port" optional="hide"/>
                            <field name="delivery_address_port" optional="hide"/>
                            <field name="destination_customs_clearance" optional="hide"/>
                            <field name="price_quoted_ff" optional="hide"/>
                            <field name="container_size_sea" optional="hide"/>
                            <field name="transit_time_cit" optional="hide"/>
                            <field name="quote_validation_date" optional="hide"/>
                            <field name="price"/>
                        </list>
                    </field>
                </page>

                <page name="logistics_details" string="Logistics Details"  invisible="0">
                    <group>
                        <group>
                            <field name="logistics_company_id" invisible="0"/>
                            <field name="logistics_company_main" invisible="1"/>
                            <field name="packing_request"/>
                            <field name="notes_cit"/>
                            <field name="pickup_address" placeholder="Enter pickup location..."/>
                            <field name="delivery_address" placeholder="Enter delivery location..."/>
                            <field name="incoterms_cit"/>
                            <field name="weight_cit"/>
                            <field name="booking_number_cit"/>
                            <field name="bol_status"/>
                            <field name="shipment_status"/>
                            <field name="charge_to_customer"/>
                            <field name="document_attachment_ids" widget="many2many_binary"/>

                        </group>
                    </group>
                </page>


            </xpath>

            <!-- Removing the existing field -->
            <xpath expr="//field[@name='origin']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>

</odoo>