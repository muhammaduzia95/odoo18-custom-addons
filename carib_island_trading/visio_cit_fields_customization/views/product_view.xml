<odoo>

    <!--  Product Template Form view -->
    <record id="view_product_template_form_inherit_size" model="ir.ui.view">
        <field name="name">product.template.form.inherit.size</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="size"/>
                <field name="cit_case_qty"/>
            </xpath>

            <field name="categ_id" position="attributes">
                <attribute name="string">Brand</attribute>
            </field>

            <field name="default_code" position="attributes">
                <attribute name="string">Item Code</attribute>
            </field>

            <field name="barcode" position="attributes">
                <attribute name="string">UPC</attribute>
            </field>
        </field>
    </record>

    <!--  Product Template Tree view -->
    <record id="product_template_tree_view_inherit_strings" model="ir.ui.view">
        <field name="name">product.template.tree.inherit.strings</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="attributes">
                <attribute name="string">Brand</attribute>
            </field>
            <field name="default_code" position="attributes">
                <attribute name="string">Item Code</attribute>
            </field>
            <field name="barcode" position="attributes">
                <attribute name="string">UPC</attribute>
            </field>
        </field>
    </record>

    <!--  Product Product Form view -->
    <record id="product_product_form_view_inherit_size" model="ir.ui.view">
        <field name="name">product.product.form.inherit.size</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="size"/>
            </xpath>

            <field name="categ_id" position="attributes">
                <attribute name="string">Brand</attribute>
            </field>

            <field name="default_code" position="attributes">
                <attribute name="string">Item Code</attribute>
            </field>

            <field name="barcode" position="attributes">
                <attribute name="string">UPC</attribute>
            </field>

        </field>
    </record>

    <!--  Product Product Tree view -->
    <record id="product_product_tree_view_inherit_strings" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.strings</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="attributes">
                <attribute name="string">Brand</attribute>
            </field>
            <field name="default_code" position="attributes">
                <attribute name="string">Item Code</attribute>
            </field>
            <field name="barcode" position="attributes">
                <attribute name="string">UPC</attribute>
            </field>
        </field>
    </record>


</odoo>
