<?xml version="1.0" encoding="utf-8"?>
<!--carib_island_trading\visio_cit_fields_customization\report\sale_order_report_view.xml-->
<odoo>
    <template id="report_saleorder_document_inherit_columns" inherit_id="sale.report_saleorder_document">

        <!-- Replacing the div of Salesperson and adding Validation Date field-->
        <xpath expr="//div[@id='informations']/div[last()]" position="replace">
            <div t-if="doc.quote_validation_cit" class="col">
                <strong>Quote Validation Date</strong>
                <div t-field="doc.quote_validation_cit" t-options='{"widget": "date"}'/>
            </div>
        </xpath>

        <xpath expr="//table[contains(@class,'o_main_table')]/thead" position="before">
            <!-- ==== column-visibility flags ==== -->
            <t t-set="has_taxes" t-value="False"/>
            <t t-set="has_region" t-value="False"/>
            <t t-set="has_hs_code" t-value="False"/>
            <t t-set="has_item_code" t-value="False"/>
            <t t-set="has_upc" t-value="False"/>
            <t t-set="has_brand" t-value="False"/>
            <t t-set="has_size" t-value="False"/>

            <!-- scan all order-lines once -->
            <t t-foreach="doc.order_line" t-as="l">
                <t t-if="len(l.tax_id)">
                    <t t-set="has_taxes" t-value="True"/>
                </t>
                <t t-if="l.region_cit">
                    <t t-set="has_region" t-value="True"/>
                </t>
                <t t-if="l.hs_code_cit">
                    <t t-set="has_hs_code" t-value="True"/>
                </t>
                <t t-if="l.product_id.default_code">
                    <t t-set="has_item_code" t-value="True"/>
                </t>
                <t t-if="l.product_id.barcode">
                    <t t-set="has_upc" t-value="True"/>
                </t>
                <t t-if="l.product_id.categ_id">
                    <t t-set="has_brand" t-value="True"/>
                </t>
                <t t-if="l.product_id.size">
                    <t t-set="has_size" t-value="True"/>
                </t>
            </t>
        </xpath>

        <xpath expr="//table[contains(@class,'o_main_table')]/thead/tr" position="replace">
            <tr>
                <th t-if="has_region" class="text-start">Region</th>
                <th t-if="has_hs_code" class="text-start">H.S Code</th>
                <th t-if="has_item_code" class="text-start">Item Code</th>
                <th t-if="has_upc" class="text-start">UPC</th>
                <th t-if="has_brand" class="text-start">Brand</th>
                <th name="th_description" class="text-start">Description</th>
                <th t-if="has_size" class="text-start">Size</th>
                <th name="th_uom" class="text-end text-nowrap">UoM</th>
                <th name="th_quantity" class="text-end text-nowrap">CS Order</th>
                <th name="th_units_quantity" class="text-end text-nowrap">Pcs Order</th>
                <th name="th_priceunit" class="text-end text-nowrap">CS Price</th>
                <th name="th_price_per_unit" class="text-end text-nowrap">Unit Price</th>
                <th name="th_discount" t-if="display_discount" class="text-end">
                    <span>Disc.%</span>
                </th>
                <th name="th_taxes" t-if="has_taxes" class="text-end">Taxes</th>

                <th name="th_subtotal" class="text-end">
                    <span>Amount</span>
                </th>
            </tr>
        </xpath>

        <xpath expr="//table[contains(@class,'o_main_table')]/tbody" position="replace">
            <tbody class="sale_tbody">

                <t t-set="current_subtotal" t-value="0"/>
                <t t-foreach="lines_to_report" t-as="line">
                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>
                    <tr
                            t-att-class="'fw-bold o_line_section' if (
                                line.display_type == 'line_section'
                                or line.product_type == 'combo'
                            )
                            else 'fst-italic o_line_note' if line.display_type == 'line_note'
                            else ''">

                        <t t-if="not line.display_type and line.product_type != 'combo'">

                            <!-- Region -->
                            <td t-if="has_region" class="text-start">
                                <span t-field="line.region_cit"/>
                            </td>

                            <!-- H.S Code -->
                            <td t-if="has_hs_code" class="text-start">
                                <span t-field="line.hs_code_cit"/>
                            </td>

                            <!-- Item Code -->
                            <td t-if="has_item_code" class="text-start">
                                <span t-field="line.product_id.default_code"/>
                            </td>

                            <!-- UPC -->
                            <td t-if="has_upc" class="text-start">
                                <span t-field="line.product_id.barcode"/>
                            </td>

                            <!-- Brand -->
                            <td t-if="has_brand" class="text-start">
                                <span t-esc="line.product_id.categ_id.display_name"/>
                            </td>

                            <td name="td_name">
                                <span t-field="line.name">Bacon Burger</span>
                            </td>

                            <!-- Size -->
                            <td t-if="has_size" class="text-start">
                                <span t-field="line.product_id.size"/>
                            </td>

                            <!-- UoM -->
                            <td class="text-start">
                                <span t-field="line.product_uom"/>
                            </td>

                            <td name="td_quantity"
                                t-attf-class="text-end {{ 'text-nowrap' if (not line.product_packaging_id or len(line.product_packaging_id.name) &lt; 10) else '' }}">
                                <span t-field="line.product_uom_qty">3</span>
<!--                                <span t-field="line.product_uom">units</span>-->
<!--                                <span t-if="line.product_packaging_id">-->
<!--                                    (-->
<!--                                    <span t-field="line.product_packaging_qty"-->
<!--                                          t-options='{"widget": "integer"}'/>-->
<!--                                    <span t-field="line.product_packaging_id"/>)-->
<!--                                </span>-->
                            </td>

                            <!-- Units Quantity -->
                            <td name="td_units_quantity" class="text-end text-nowrap">
                                <span t-field="line.units_quantity"/>
                            </td>

                            <td name="td_priceunit" class="text-end text-nowrap">
                                <span t-field="line.price_unit">3</span>
                            </td>

                            <td name="td_per_unit_price" class="text-end text-nowrap">
                                <span t-field="line.per_unit_price" t-options='{"widget": "float", "precision": 2}'/>
                            </td>

                            <td t-if="display_discount" class="text-end">
                                <span t-field="line.discount">-</span>
                            </td>


                            <t t-if="has_taxes">
                                <t t-set="taxes"
                                   t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_id])"/>
                                <td name="td_taxes"
                                    t-attf-class="text-end {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                    <span t-out="taxes">Tax 15%</span>
                                </td>
                            </t>


                            <td t-if="not line.is_downpayment" name="td_subtotal"
                                class="text-end o_price_total">
                                <span t-field="line.price_subtotal">27.00</span>
                            </td>
                        </t>
                        <t t-elif="line.display_type == 'line_section' or line.product_type == 'combo'">
                            <td name="td_section_line" colspan="99">
                                <span t-field="line.name">A section title</span>
                            </td>
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subtotal" t-value="0"/>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <td name="td_note_line" colspan="99">
                                <span t-field="line.name">A note, whose content usually applies to the section
                                    or product above.
                                </span>
                            </td>
                        </t>
                    </tr>

                    <t
                            t-if="current_section and (
                                line_last
                                or lines_to_report[line_index+1].display_type == 'line_section'
                                or lines_to_report[line_index+1].product_type == 'combo'
                                or (
                                    line.combo_item_id
                                    and not lines_to_report[line_index+1].combo_item_id
                                )
                            ) and not line.is_downpayment"
                    >
                        <t t-set="current_section" t-value="None"/>
                        <tr class="is-subtotal text-end">
                            <td name="td_section_subtotal" colspan="99">
                                <strong class="mr16">Subtotal</strong>
                                <span
                                        t-out="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                >31.05
                                </span>
                            </td>
                        </tr>
                    </t>
                </t>
            </tbody>

        </xpath>

        <!-- Replacing the Terms and Condition from sale's pdf -->
        <xpath expr="//div[span[@t-field='doc.note']]" position="replace">
        </xpath>


    </template>
</odoo>
