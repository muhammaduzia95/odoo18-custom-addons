<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_purchaseorder_document_inherit_columns" inherit_id="purchase.report_purchaseorder_document">

        <!-- Replace the one-line contact widget that prints the address block -->
        <xpath expr="//t[@t-set='address']/div[@t-field='o.partner_id']" position="replace">
            <!-- Name first, huge -->
            <p style="font-size:26px; font-weight:700; margin:0;">
                <span t-field="o.partner_id.name"/>
            </p>

            <!-- Everything else (address, phone, VAT) in normal size -->
            <div t-field="o.partner_id"
                 t-options='{
                     "widget": "contact",
                     "fields": ["address", "phone", "vat"],
                     "no_marker": True,
                     "phone_icons": True
                 }'/>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/thead" position="before">
            <t t-set="has_taxes"
               t-value="any(len(l.taxes_id) &gt; 0 for l in o.order_line)"/>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/thead" position="replace">
            <thead>
                <tr>
                    <th class="text-start">
                        <strong>Item Code</strong>
                    </th>
                    <th class="text-start">
                        <strong>UPC</strong>
                    </th>
                    <th class="text-start">
                        <strong>Brand</strong>
                    </th>
                    <th name="th_description" class="text-start">
                        <strong>Description</strong>
                    </th>
                    <th class="text-start"><strong>Size</strong></th>
                    <th class="text-start"><strong>UoM</strong></th>
                    <th name="th_quantity" class="text-end">
                        <strong>CS Order</strong>
                    </th>
                    <th name="th_units_quantity" class="text-end">
                        <strong>Pcs Order</strong>
                    </th>

                    <th name="th_case_price" class="text-end">
                        <strong>CS Price</strong>
                    </th>

                    <th name="th_price_unit" class="text-end">
                        <strong>Unit Price</strong>
                    </th>
                    <th name="th_discount" class="text-end">
                        <strong>Disc.</strong>
                    </th>
                    <th name="th_taxes" t-if="has_taxes" class="text-end">
                        <strong>Taxes</strong>
                    </th>
                    <th name="th_subtotal" class="text-end">
                        <strong>Amount</strong>
                    </th>
                </tr>
            </thead>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/tbody" position="replace">
            <tbody>
                <t t-set="current_subtotal" t-value="0"/>
                <t t-foreach="o.order_line" t-as="line">
                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>

                    <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                        <t t-if="not line.display_type">

                            <!-- Item Code -->
                            <td class="text-start">
                                <span t-field="line.product_id.default_code"/>
                            </td>

                            <!-- UPC -->
                            <td class="text-start">
                                <span t-field="line.product_id.barcode"/>
                            </td>

                            <!-- Brand -->
                            <td class="text-start">
                                <span t-esc="line.product_id.categ_id.display_name"/>
                            </td>

                            <td id="product" class="text-start">
                                <span t-field="line.name"/>
                            </td>

                            <!-- Size -->
                            <td class="text-start">
                                <span t-field="line.product_id.size"/>
                            </td>

                            <td class="text-end">
                                <span t-esc="line.product_uom.name"/>
                            </td>

                            <td class="text-end">
                                <span t-esc="line.product_qty"/>
                            </td>

                            <!-- Units Quantity -->
                            <td class="text-end text-nowrap">
                                <span t-field="line.units_quantity"/>
                            </td>

                            <td class="text-end">
                                <span t-field="line.price_unit"/>
                            </td>

                            <td class="text-end">
                                <span t-field="line.price_per_unit"/>
                            </td>


                            <td class="text-end">
                                <span class="text-align-bottom"><span t-field="line.discount"/>%
                                </span>
                            </td>
                            <t t-if="has_taxes">
                                <td class="text-end">
                                    <span t-out="', '.join([(tax.invoice_label or tax.name) for tax in line.taxes_id])"/>
                                </td>
                            </t>
                            <td class="text-end">
                                <span t-field="line.price_subtotal"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </t>
                        <t t-if="line.display_type == 'line_section'">
                            <td colspan="99" id="section">
                                <span t-field="line.name"/>
                            </td>
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subtotal" t-value="0"/>
                        </t>
                        <t t-if="line.display_type == 'line_note'">
                            <td colspan="99" id="note">
                                <span t-field="line.name"/>
                            </td>
                        </t>
                    </tr>
                    <t t-if="current_section and (line_last or o.order_line[line_index+1].display_type == 'line_section')">
                        <tr class="is-subtotal text-end">
                            <td colspan="99" id="subtotal">
                                <strong class="mr16">Subtotal</strong>
                                <span
                                        t-out="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                />
                            </td>
                        </tr>
                    </t>
                </t>
            </tbody>

        </xpath>

        <xpath expr="//p[@t-field='o.notes']" position="replace"/>

        <xpath expr="//strong[normalize-space()='Payment Terms:']" position="replace"/>


    </template>

</odoo>
