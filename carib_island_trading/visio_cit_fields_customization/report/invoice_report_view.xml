<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document_inherit_columns" inherit_id="account.report_invoice_document">

        <xpath expr="//table[contains(@class,'o_has_total_table')]/thead" position="before">

            <!-- ❶  set all column-visibility flags in one shot -->
            <t t-set="has_taxes"
               t-value="any(l.tax_ids                  for l in o.invoice_line_ids)"/>

            <t t-set="has_region"
               t-value="any(l.region_cit_inv           for l in o.invoice_line_ids)"/>

            <t t-set="has_hs_code"
               t-value="any(l.hs_code_cit_inv          for l in o.invoice_line_ids)"/>

            <t t-set="has_item_code"
               t-value="any(l.product_id.default_code  for l in o.invoice_line_ids)"/>

            <t t-set="has_upc"
               t-value="any(l.product_id.barcode       for l in o.invoice_line_ids)"/>

            <t t-set="has_brand"
               t-value="any(l.product_id.categ_id      for l in o.invoice_line_ids)"/>

            <t t-set="has_size"
               t-value="any(l.product_id.size          for l in o.invoice_line_ids)"/>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/thead" position="before">
            <t t-set="has_taxes" t-value="False"/>
            <t t-foreach="o.invoice_line_ids" t-as="l">
                <t t-if="len(l.tax_ids)">
                    <t t-set="has_taxes" t-value="True"/>
                </t>
            </t>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/thead" position="replace">

            <thead>
                <tr>
                    <th t-if="has_region" class="text-start">Region</th>
                    <th t-if="has_hs_code" class="text-start">H.S Code</th>
                    <th t-if="has_item_code" class="text-start">Item Code</th>
                    <th t-if="has_upc" class="text-start">UPC</th>
                    <th t-if="has_brand" class="text-start">Brand</th>
                    <th name="th_description" class="text-start">
                        <span>Description</span>
                    </th>
                    <th t-if="has_size" class="text-start">Size</th>
                    <th class="text-start">UoM</th>
                    <th name="th_quantity" class="text-end">
                        <span>CS Order</span>
                    </th>
                    <th name="th_units_quantity" class="text-end">
                        <span>Pcs Order</span>
                    </th>
                    <th name="th_priceunit" class="text-end text-nowrap">CS Price</th>
                    <th name="th_price_per_unit" class="text-end text-nowrap">Unit Price</th>
                    <th name="th_discount" t-if="display_discount"
                        t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Disc.%</span>
                    </th>

                    <th name="th_taxes"
                        t-if="has_taxes"
                        t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Taxes</span>
                    </th>

                    <th name="th_subtotal" class="text-end">
                        <span>Amount</span>
                    </th>
                </tr>
            </thead>
        </xpath>

        <xpath expr="//table[contains(@class,'o_has_total_table')]/tbody" position="replace">
            <tbody class="invoice_tbody">


                <t t-set="current_subtotal" t-value="0"/>
                <t t-set="current_total" t-value="0"/>
                <t t-set="lines"
                   t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                <!--                <t t-set="has_taxes" t-value="any(line.tax_ids for line in lines)"/>-->


                <t t-foreach="lines" t-as="line">
                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>
                    <t t-set="current_total" t-value="current_total + line.price_total"/>

                    <tr t-att-class="'fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                        <t t-if="line.display_type == 'product'" name="account_invoice_line_accountable">

                            <!-- Region -->
                            <t t-if="has_region">
                                <td class="text-start">
                                    <span t-field="line.region_cit_inv"/>
                                </td>
                            </t>

                            <!-- H.S Code -->
                            <t t-if="has_hs_code">
                                <td class="text-start">
                                    <span t-field="line.hs_code_cit_inv"/>
                                </td>
                            </t>


                            <!-- Item Code -->
                            <t t-if="has_item_code">
                                <td class="text-start">
                                    <span t-field="line.product_id.default_code"/>
                                </td>
                            </t>


                            <!-- UPC -->
                            <t t-if="has_upc">
                                <td class="text-start">
                                    <span t-field="line.product_id.barcode"/>
                                </td>
                            </t>

                            <!-- Brand -->
                            <t t-if="has_brand">
                                <td class="text-start">
                                    <span t-esc="line.product_id.categ_id.display_name"/>
                                </td>
                            </t>

                            <td name="account_invoice_line_name">
                                <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">Bacon Burger
                                </span>
                            </td>

                            <!-- Size -->
                            <t t-if="has_size">
                                <td class="text-start">
                                    <span t-field="line.product_id.size"/>
                                </td>
                            </t>

                            <!-- Units -->
                            <td name="td_quantity" class="text-end text-nowrap">
                                <span t-field="line.product_uom_id.name" groups="uom.group_uom">units</span>
                            </td>

                            <!-- Pcs Order -->
                            <td name="td_quantity" class="text-end text-nowrap">
                                <span t-field="line.quantity"/>
                            </td>

                            <!-- Units Quantity -->
                            <td name="td_units_quantity" class="text-end text-nowrap">
                                <span t-field="line.units_quantity"/>
                            </td>

                            <td name="td_price_unit"
                                t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                <span class="text-nowrap" t-field="line.price_unit">9.00</span>
                            </td>

                            <td name="td_per_unit_price" class="text-end text-nowrap">
                                <span t-field="line.price_per_unit" t-options='{"widget": "float", "precision": 2}'/>
                            </td>

                            <td name="td_discount" t-if="display_discount"
                                t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                <span class="text-nowrap" t-field="line.discount">0</span>
                            </td>

                            <t t-if="has_taxes">
                                <t t-set="taxes"
                                   t-value="', '.join([(tax.invoice_label or tax.name) for tax in line.tax_ids])"/>
                                <td name="td_taxes"
                                    t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                    <span t-out="taxes" id="line_tax_ids">Tax 15%</span>
                                </td>
                            </t>

                            <td name="td_subtotal" class="text-end o_price_total">
                                <span class="text-nowrap" t-field="line.price_subtotal">27.00</span>
                            </td>
                        </t>
                        <t t-elif="line.display_type == 'line_section'">
                            <td colspan="99">
                                <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">A section
                                    title
                                </span>
                            </td>
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subtotal" t-value="0"/>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <td colspan="99">
                                <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}">A note, whose
                                    content usually applies to the section or product above.
                                </span>
                            </td>
                        </t>
                    </tr>

                    <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                        <tr class="is-subtotal text-end">
                            <td colspan="99">
                                <strong class="mr16">Subtotal</strong>
                                <span
                                        t-out="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                >31.05
                                </span>
                            </td>
                        </tr>
                    </t>
                </t>
            </tbody>

        </xpath>

        <xpath expr="//div[@name='comment']" position="replace"/>

    </template>

</odoo>
