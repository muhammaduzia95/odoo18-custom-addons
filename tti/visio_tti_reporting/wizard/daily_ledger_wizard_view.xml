<odoo>
    <record id="view_daily_ledger_wizard_form" model="ir.ui.view">
        <field name="name">daily.ledger.wizard.form</field>
        <field name="model">daily.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Ledger Report">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                        <field name="customer"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_ledger_excel"
                            type="object"
                            string="Generate Report"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_daily_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Daily Ledger Report</field>
        <field name="res_model">daily.ledger.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_daily_ledger_report"
              name="Daily Ledger Report"
              parent="visio_tti_reporting.menu_tti_reports"
              action="action_daily_ledger_wizard"
              sequence="30"/>
</odoo>
