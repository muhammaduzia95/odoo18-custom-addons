<odoo>
    <record id="view_invoice_daily_summary_wizard_form" model="ir.ui.view">
        <field name="name">invoice.daily.summary.wizard.form</field>
        <field name="model">invoice.daily.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Daily Summary Report" version="7.0">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_excel_report" type="object" class="btn-primary"
                            string="Generate Report"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_daily_summary_wizard" model="ir.actions.act_window">
        <field name="name">Invoice Daily Summary Report</field>
        <field name="res_model">invoice.daily.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_invoice_daily_summary_report"
              name="Invoice Daily Summary Report"
              parent="visio_tti_reporting.menu_tti_reports"
              action="action_invoice_daily_summary_wizard"
              sequence="10"/>
</odoo>
