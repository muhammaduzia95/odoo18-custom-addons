<odoo>
    <record id="view_daily_summary_wizard_form" model="ir.ui.view">
        <field name="name">daily.summary.wizard.form</field>
        <field name="model">daily.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Summary Report">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_daily_excel"
                            type="object"
                            string="Generate Report"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_daily_summary_wizard" model="ir.actions.act_window">
        <field name="name">Daily Summary Report</field>
        <field name="res_model">daily.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_daily_summary_report"
              name="Daily Summary Report"
              parent="visio_tti_reporting.menu_tti_reports"
              action="action_daily_summary_wizard"
              sequence="20"/>
</odoo>
