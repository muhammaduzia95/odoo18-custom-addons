<odoo>
    <record id="purchase_order_form_inherit_tti" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.tti</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="can_create_bill" invisible="1"/>
            </xpath>
            <xpath expr="//header/button[@name='action_create_invoice'][1]" position="attributes">
                <attribute name="invisible">not can_create_bill</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_create_invoice'][2]" position="attributes">
                <attribute name="invisible">not can_create_bill</attribute>
            </xpath>

            <!--            <xpath expr="//sheet/group/group/field[@name='partner_id']" position="attributes">-->
            <!--                <attribute name="domain">[('tti_company_category', '=', 'default')]</attribute>-->
            <!--            </xpath>-->
            <xpath expr="//sheet/group/group/field[@name='partner_id']" position="after">
                <field name="applicant_id"
                       context="{'parent_id': partner_id}"
                       readonly="state in ['cancel', 'done', 'purchase']"
                       domain="[('parent_id', '=', partner_id)]"/>
            </xpath>

<!--            <xpath expr="//notebook/page[@name='products']/field[@name='order_line']/list" position="attributes">-->
<!--                <attribute name="create">0</attribute>-->
<!--            </xpath>-->
<!--            <xpath expr="//notebook/page[@name='products']/field[@name='order_line']/form" position="attributes">-->
<!--                <attribute name="create">0</attribute>-->
<!--            </xpath>-->

            <xpath expr="//sheet/group/group[2]" position="inside">
                <field name="project_tags" widget="many2many_tags"
                       groups="visio_tti_emp_purchase_requisition.employee_requisition_manager" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_list_inherit_tti" model="ir.ui.view">
        <field name="name">purchase.order.list.inherit.tti</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="project_tags" widget="many2many_tags" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_search_inherit_tti" model="ir.ui.view">
        <field name="name">purchase.order.search.inherit.tti</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="project_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
