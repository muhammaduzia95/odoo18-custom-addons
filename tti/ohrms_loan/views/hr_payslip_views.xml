<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_inherit_regen" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.regenerate</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_regenerate_entries_and_lines"
                        string="Update Work Entries"
                        type="object"
                        class="btn-primary"/>
            </header>
        </field>
    </record>

    <record id="view_hr_payslip_run_form_inherit_regenerate" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.regenerate.button</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_regenerate_all_payslips"
                        type="object"
                        string="Regenerate Work Entries"
                        class="oe_highlight"
                        icon="fa-refresh"/>
            </xpath>
        </field>
    </record>


</odoo>
