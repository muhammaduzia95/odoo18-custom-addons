<odoo>
    <record id="category_hr_loan_advances" model="ir.module.category">
        <field name="name">Loans and Advances</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_hr_loan_submit" model="res.groups">
        <field name="name">Display Loan/Advance Submit Button</field>
        <field name="category_id" ref="ohrms_loan.category_hr_loan_advances"/>
    </record>

    <record id="group_hr_loan_approve" model="res.groups">
        <field name="name">Display Loan/Advance Approve Button</field>
        <field name="category_id" ref="ohrms_loan.category_hr_loan_advances"/>
    </record>

    <record id="group_hr_loan_refuse" model="res.groups">
        <field name="name">Display Loan/Advance Refuse Button</field>
        <field name="category_id" ref="ohrms_loan.category_hr_loan_advances"/>
    </record>
</odoo>