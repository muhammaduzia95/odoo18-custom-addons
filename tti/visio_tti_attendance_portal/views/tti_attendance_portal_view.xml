<odoo>

    <!-- Sub Menu -->
    <record id="group_attendance_portal_request" model="res.groups">
        <field name="name">Attendance / Missed Attendance / Manager Approval (HOD)</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- Action Approve -->
    <record id="group_attendance_portal_approve_btn" model="res.groups">
        <field name="name">Missed Attendance / Manager Approval / Verify Button (HOD)</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- List View -->
    <record id="view_tti_attendance_portal_tree" model="ir.ui.view">
        <field name="name">tti.attendance.portal.request.list</field>
        <field name="model">tti.attendance.portal.request</field>
        <field name="arch" type="xml">
            <list editable="bottom" create="false">
                <field name="employee_id" readonly="1"/>
                <field name="check_in" readonly="1"/>
                <field name="check_out" readonly="1"/>
                <field name="reason" readonly="1"/>
                <field name="state" readonly="1"/>

                <!-- Approve button -->
                <button name="action_verify"
                        type="object"
                        string="Verify"
                        class="btn btn-link text-success"
                        invisible="state != 'draft'"
                        groups="visio_tti_attendance_portal.group_attendance_portal_approve_btn,base.group_system"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tti_attendance_portal_request" model="ir.actions.act_window">
        <field name="name">Attendance Requests</field>
        <field name="res_model">tti.attendance.portal.request</field>
        <field name="view_mode">list</field>
        <field name="domain">[('state','=','draft'), ('employee_id.parent_id','!=',False)]</field>
    </record>

    <!-- Sub Menu -->
    <menuitem id="menu_tti_attendance_portal_requests"
              name="Manager Approval"
              parent="visio_tti_attendance_portal.menu_tti_hr_attendance_approval_root"
              action="action_tti_attendance_portal_request"
              groups="visio_tti_attendance_portal.group_attendance_portal_request,base.group_system"/>

</odoo>
