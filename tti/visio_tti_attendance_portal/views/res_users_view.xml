<odoo>

    <record id="view_users_form_marketing_attendance_portal_access" model="ir.ui.view">
        <field name="name">res.users.form.marketing.attendance.portal.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Add checkbox inside Access Rights tab -->
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Marketing Portal" groups="base.group_system">

                    <field name="marketing_attendance_portal_access"/>
                    <field name="manager_approval_portal_access"/>

                </group>
            </xpath>

        </field>
    </record>

</odoo>
