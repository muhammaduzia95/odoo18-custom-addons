<odoo>
    <template id="report_blank_pdf_template">
        <t t-name="visio_tti_cheque_print.report_blank_pdf_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.basic_layout">
                        <div class="page">
                            <div class="d-flex" style="margin-left:150px; width:100%; height:100%;">
                                <div style="margin-top:170px; margin-right:170px;">
                                    <p>
                                        <t t-if="o.date">
                                            <t t-esc="o.date.strftime('%d/%m/%y')"/>
                                        </t>
                                    </p>
                                    <p>
                                        <t t-if="o.partner_id">
                                            <t t-esc="o.partner_id.name"/>
                                        </t>
                                    </p>
                                    <p>
                                        <t t-if="o.amount">
                                            <t t-esc="o.amount"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                            /
                                        </t>
                                    </p>
                                </div>

                                <div style="margin-top:130px; margin-right:400px;">
                                    <t t-if="o.is_cross">
                                        <p style="border-top:1px solid black; border-bottom:1px solid black; width:100px; font-size:12px;">A/C PAYEE ONLY</p>
                                    </t>
                                    <p style="margin-top:40px;">
                                        <t t-if="o.partner_id">
                                            <t t-esc="o.partner_id.name"/>
                                        </t>
                                    </p>
                                    <p style="margin-left:40px;">
                                        <t t-if="o.amount">
                                            <t t-esc="o.currency_id.amount_to_text(o.amount)"/>
                                        </t>
                                    </p>
                                </div>

                                <div style="margin-top:150px;">
                                    <p style="text-align:right;">
                                        <t t-if="o.date">
                                            <t t-esc="o.date.strftime('%d/%m/%y')"/>
                                        </t>
                                    </p>
                                    <p style="margin-top:30px; text-align:right;">
                                        <t t-if="o.amount">
                                            <t t-esc="o.amount"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                            /=
                                        </t>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <record id="paperformat_envelope_10" model="report.paperformat">
        <field name="name">#10 Envelope</field>
        <field name="format">custom</field>
        <field name="page_width">104</field>
        <field name="page_height">241</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_blank_pdf" model="ir.actions.report">
        <field name="name">Blank PDF</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_cheque_print.report_blank_pdf_template</field>
        <field name="report_file">visio_tti_cheque_print.report_blank_pdf_template</field>
        <field name="paperformat_id" ref="visio_tti_cheque_print.paperformat_envelope_10"/>
        <field name="print_report_name">'Blank PDF - %s' % (object.name)</field>
    </record>

</odoo>
