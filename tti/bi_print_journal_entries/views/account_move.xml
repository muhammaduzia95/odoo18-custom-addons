<odoo>
    <record id="view_move_form_inherit_voucher_date" model="ir.ui.view">
        <field name="name">account.move.form.voucher.date</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group[@id='header_right_group']/field[@name='date']" position="after">
                <field name="voucher_date" invisible="move_type not in ['entry']"/>
            </xpath>
            <xpath expr="//sheet/group/group[@id='header_right_group']/div[@name='journal_div']/field[@name='journal_id']" position="attributes">
                <attribute name="string">Voucher Type</attribute>
            </xpath>
            <xpath expr="//notebook/page[@name='aml_tab']/field[@name='line_ids']/list/field[@name='partner_id']" position="attributes">
                <attribute name="string">Analysis Name</attribute>
            </xpath>
            <xpath expr="//notebook/page[@name='aml_tab']/field[@name='line_ids']/list/field[@name='name']" position="attributes">
                <attribute name="string">Remarks</attribute>
            </xpath>
            <xpath expr="//sheet/group/group[@id='header_left_group']/field[@name='ref'][2]" position="attributes">
                <attribute name="widget">text</attribute>
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>
            <xpath expr="//sheet/group/group[@id='header_left_group']/field[@name='ref'][2]" position="after">
                <field name="paid_to" readonly="state != 'draft'"/>
                 <field name="instr_no" readonly="state != 'draft'"/>
                 <field name="bill_no" readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>

</odoo>