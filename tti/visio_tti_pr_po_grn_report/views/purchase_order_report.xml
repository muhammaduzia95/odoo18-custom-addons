<odoo>
    <template id="report_purchase_custom_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <div class="mb-3 d-flex justify-content-between" style="margin-bottom:30px; font-size:12px;">
                            <!-- Supplier Info -->
                            <div>
                                <span>Supplier Information:</span>
                                <br/>
                                <t t-if="o.partner_id">
                                    <t t-esc="o.partner_id.name"/>
                                    <br/>
                                    <t t-if="o.partner_id.vat">
                                        <span>NTN:
                                            <t t-esc="o.partner_id.vat"/>
                                        </span>
                                        <br/>
                                    </t>
                                    <t t-if="o.partner_id.phone">
                                        <span t-esc="o.partner_id.phone"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.applicant_id">
                                        <span t-esc="o.applicant_id.name"/>
                                        <br/>
                                    </t>
                                </t>
                            </div>

                            <!-- Shipping Address -->
                            <div style=" text-align: right;">
                                <span>Tti/PUR/QR-06, Rev 04 15/05/25</span>
                                <br/>
                                <span>Shipping address:</span>
                                <br/>
                                <t t-if="o.company_id">
                                    <span t-esc="o.company_id.name"/>
                                    <br/>
                                    <t t-if="o.company_id.street">
                                        <span t-esc="o.company_id.street"/>
                                        <t t-if="o.company_id.street2">
                                            ,
                                            <t t-esc="o.company_id.street2"/>
                                        </t>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.city or o.company_id.state_id or o.company_id.zip">
                                        <span t-if="o.company_id.city" t-esc="o.company_id.city"/>
                                        <t t-if="o.company_id.state_id">
                                            <span>,
                                                <t t-esc="o.company_id.state_id.name"/>
                                            </span>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span>
                                                <t t-esc="o.company_id.zip"/>
                                            </span>
                                        </t>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.country_id">
                                        <span t-esc="o.company_id.country_id.name"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.phone">
                                        <span t-esc="o.company_id.phone"/>
                                        <br/>
                                    </t>
                                </t>
                            </div>
                        </div>

                        <!-- Purchase Order Header -->
                        <div style="margin-bottom:30px;">
                            <h2 style="color: #2a4b8d; margin-top:20px;">
                                <strong>
                                    Purchase Order
                                    <t t-if="o.name">#
                                        <t t-esc="o.name"/>
                                    </t>
                                </strong>

                            </h2>
                        </div>

                        <div class="d-flex justify-content-between" style="margin-bottom: 20px; font-size:12px;">
                            <!-- Purchase Representative -->
                            <div class="col-2">
                                <span style="color: goldenrod;">Purchase Representative:</span>
                                <br/>
                                <t t-if="o.user_id">
                                    <span t-esc="o.user_id.name"/>
                                    <t t-if="o.user_id.partner_id.phone">
                                        (<t t-esc="o.user_id.partner_id.phone"/>)
                                    </t>
                                </t>
                            </div>

                            <!-- Order Date -->
                            <div class="col-2">
                                <strong>Order Date:</strong>
                                <br/>
                                <t t-if="o.state in ['draft', 'sent', 'cancel']">
                                    <t t-if="o.date_order">
                                        <t t-esc="o.date_order.strftime('%d/%m/%Y')"/>
                                    </t>
                                </t>
                                <t t-if="o.state not in ['draft', 'sent', 'cancel']">
                                    <t t-if="o.date_approve">
                                        <t t-esc="o.date_approve.strftime('%d/%m/%Y')"/>
                                    </t>
                                </t>
                            </div>

                            <!-- Incoterm -->
                            <div class="col-2">
                                <strong>Incoterm:</strong>
                                <br/>
                                <t t-if="o.incoterm_id">
                                    <t t-esc="o.incoterm_id.name"/>
                                </t>
                            </div>

                            <!-- Payment Terms -->
                            <div class="col-2">
                                <strong>Payment Terms:</strong>
                                <br/>
                                <t t-if="o.payment_term_id">
                                    <t t-esc="o.payment_term_id.name"/>
                                </t>
                            </div>

                            <!-- Currency -->
                            <div class="col-2">
                                <strong>Currency:</strong>
                                <br/>
                                <t t-if="o.currency_id">
                                    <t t-esc="o.currency_id.name"/>
                                </t>
                            </div>
                        </div>

                        <div style="margin-top: 50px; font-size: 12px; line-height: 1.6;">
                            <span style="text-decoration:underline; font-weight:bold;">Note :</span>
                            If you do not agree with any terms and conditions of this Purchase Order, please inform us
                            in writing within
                            3 days from the date of issue of this order, otherwise this order will be considered as
                            accepted by you.
                            Kindly make all correspondence to our head office at
                            <b>347-S, Quaid-e-Azam Industrial Estate, Kot Lakhpat, Lahore 54770</b>
                            and quote PO number on Invoices, Delivery Challan and other relevant documents.
                            Supplies should reach "Ship To" address between
                            <b>9:00 am to 5:00 pm</b>
                            on working days.
                        </div>

                        <!-- Order Line Table -->
                        <table class="table table-sm"
                               style=" margin-top:50px; width:100%; border: 1px solid black; font-size:12px;">
                            <thead style="text-align:center;">
                                <tr style="background-color: #f2f2f2;">
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">Sr No.</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">
                                        PRODUCT DESCRIPTION
                                    </th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">QTY</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">UoM</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">UNIT PRICE</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">AMOUNT</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">GST</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">GST AMOUNT</th>
                                    <th style="border: 1px solid black; padding:5px; text-align:center;">NET AMOUNT</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- init counter once -->
                                <t t-set="i" t-value="0"/>
                                <t t-foreach="o.order_line" t-as="line">
                                    <!-- increment for each row -->
                                    <t t-set="i" t-value="i + 1"/>
                                    <tr>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;"
                                            t-esc="i"/>
                                        <td style="border: 1px solid black; padding:5px; text-align:left;"
                                            t-esc="line.name"/>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;"
                                            t-esc="line.product_qty"/>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;"
                                            t-esc="line.product_uom.name"/>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;">
                                            <span t-field="line.price_subtotal"/>
                                        </td>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;">
                                            <t t-if="line.taxes_id">
                                                <t t-foreach="line.taxes_id" t-as="tax" t-separator=", ">
                                                    <t t-esc="str(tax.amount) + '%'"/>
                                                </t>
                                            </t>
                                        </td>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;">
                                            <span t-field="line.price_tax"/>
                                        </td>
                                        <td style="border: 1px solid black; padding:5px; text-align:center;">
                                            <span t-field="line.price_total"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>


                            <!--                            <tbody>-->
                            <!--                                <t t-foreach="o.order_line" t-as="line">-->
                            <!--                                    <t t-set="index" t-value="0"/>-->
                            <!--                                    <tr>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;"-->
                            <!--                                            t-esc="index + 1"/>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:left;"-->
                            <!--                                            t-esc="line.name"/>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;"-->
                            <!--                                            t-esc="line.product_qty"/>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;"-->
                            <!--                                            t-esc="line.product_uom.name"/>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;">-->
                            <!--                                            <span t-field="line.price_unit"/>-->
                            <!--                                        </td>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;">-->
                            <!--                                            <span t-field="line.price_subtotal"/>-->
                            <!--                                        </td>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;">-->
                            <!--                                            <t t-if="line.taxes_id">-->
                            <!--                                                <t t-foreach="line.taxes_id" t-as="tax" t-separator=", ">-->
                            <!--                                                    <t t-esc="str(tax.amount) + '%'"/>-->
                            <!--                                                </t>-->
                            <!--                                            </t>-->
                            <!--                                        </td>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;">-->
                            <!--                                            <span t-field="line.price_tax" />-->
                            <!--                                        </td>-->
                            <!--                                        <td style="border: 1px solid black; padding:5px; text-align:center;">-->
                            <!--                                            <span t-field="line.price_total" />-->
                            <!--                                        </td>-->
                            <!--                                        <t t-set="index" t-value="index + 1"/>-->
                            <!--                                    </tr>-->
                            <!--                                </t>-->
                            <!--                            </tbody>-->
                        </table>

                        <!-- Totals Summary Table -->
                        <div>
                            <table style="width: 30%; float: right; font-size: 12px; margin-top: 15px; border: 1px solid black;"
                            >
                                <tr>
                                    <td style="border: 1px solid black; padding:5px;">
                                        <span>Untaxed Amount</span>
                                    </td>
                                    <td style="border: 1px solid black; text-align: right; padding:5px;">
                                        <span t-field="o.amount_untaxed"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="border: 1px solid black; padding:5px;">
                                        <span>GST Total</span>
                                    </td>
                                    <td style="border: 1px solid black; text-align: right; padding:5px;">
                                        <span t-field="o.amount_tax"/>
                                    </td>
                                </tr>
                                <tr style="background-color: #2a4b8d; color: white;">
                                    <td style="border: 1px solid black; padding:5px;">
                                        <span>Total</span>
                                    </td>
                                    <td style="border: 1px solid black; padding:5px; text-align: right;">
                                        <span t-field="o.amount_total"/>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div style="clear: both;"></div>

                        <div style="margin-top: 10px; font-size: 12px;">
                            <span style="display: inline-block;">Instructions :</span>
                            <span style="display: inline-block;" t-if="o.notes">
                                <t t-raw="o.notes"/>
                            </span>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="paperformat_custom_purchaseorder" model="report.paperformat">
        <field name="name">Custom Purchase Order Format</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="action_custom_purchase_report" model="ir.actions.report">
        <field name="name">TTI Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_pr_po_grn_report.report_purchase_custom_document</field>
        <field name="report_file">visio_tti_pr_po_grn_report.report_purchase_custom_document</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="visio_tti_pr_po_grn_report.paperformat_custom_purchaseorder"/>
    </record>
</odoo>