<odoo>
    <template id="sin_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <t t-if="o.state == 'done'">
                        <div class="page">
                            <t t-set="purchase_order"
                               t-value="env['purchase.order'].search([('group_id', '=', o.group_id.id)], limit=1)"/>

                            <span>Tti/PUR/QR-11, Rev 01 15/05/25</span>

                            <div style="margin-top:15px;">
                                <h2 style="color:#2E619B;">
                                    Stock Issue Note #
                                    <br/>
                                    <t t-if="o.name">SIN
                                        <t t-esc="o.name.split('/')[-1]"/>
                                    </t>
                                </h2>

                                <!-- IGP TIME AND Date -->
                                <div class="d-flex" style="margin-top:20px; margin-bottom:25px;">
                                    <div style="margin-right:70px;">
                                        <span style="color: #B8A055;">SIN Date:</span>
                                        <br/>
                                        <span>
                                            <t t-esc="o.scheduled_date.strftime('%d/%m/%Y') if o.scheduled_date else ''"/>
                                        </span>
                                    </div>
                                    <div style="margin-right:70px;">
                                        <span style="color: #B8A055;">Issued To :</span>
                                        <br/>
                                        <span>
                                            <t t-esc="o.partner_id.name if o.partner_id else ''"/>
                                        </span>
                                    </div>
                                    <div style="margin-right:70px;">
                                        <span style="color: #B8A055; font-weight: bold;">Department:</span>
                                        <br/>
                                        <span>
                                            <t t-if="o.partner_id.employee_ids and o.partner_id.employee_ids[0].department_id">
                                                <t t-esc="o.partner_id.employee_ids[0].department_id.name"/>
                                            </t>
                                        </span>
                                    </div>
                                    <div style="margin-right:70px;">
                                        <span style="color: #B8A055; font-weight: bold;">Branch:</span>
                                        <br/>
                                        <span>
                                            <!--                                        <t t-esc="purchase_order.date_order.strftime('%d/%m/%y') if purchase_order and purchase_order.date_order else ''"/>-->
                                        </span>
                                    </div>
                                </div>

                            </div>

                            <!-- Line items table -->
                            <table class="table table-sm"
                                   style="font-size:12px; width: 100%; border: 1px solid black; margin-top:30px;">
                                <thead class="bg-secondary">
                                    <tr>
                                        <th style="border: 1px solid black; text-align:center;">Sr. No</th>
                                        <th style="border: 1px solid black; text-align:center;">Description</th>
                                        <th style="border: 1px solid black; text-align:center;">UOM</th>
                                        <th style="border: 1px solid black; text-align:center;">Quantity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="total_qty" t-value="0"/>
                                    <t t-set="index" t-value="0"/>
                                    <t t-foreach="o.move_ids_without_package" t-as="line">
                                        <tr>
                                            <td style="border: 1px solid black; text-align:center;">
                                                <t t-esc="index + 1"/>
                                            </td>
                                            <td style="border: 1px solid black; text-align:center;">
                                                <t t-esc="line.description_picking"/>
                                            </td>
                                            <td style="border: 1px solid black; text-align:center;">
                                                <t t-esc="line.product_uom.name"/>
                                            </td>
                                            <td style="border: 1px solid black; text-align:center;">
                                                <t t-esc="line.quantity"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <div class="d-flex justify-content-center align-items-center" style="margin-top:300px;">
                                <div class="d-flex justify-content-between" style="width:70%">
                                    <div class="d-flex justify-content-center"
                                         style="border-top:1px solid black; width:25%;">
                                        <p style="margin-top:15px;">Store Incharge</p>
                                    </div>
                                    <div class="d-flex justify-content-center"
                                         style="border-top:1px solid black; width:25%;">
                                        <p style="margin-top:15px;">Received By</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="page"></div> <!-- Completely empty page -->
                    </t>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_sin" model="ir.actions.report">
        <field name="name">SIN Report</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_pr_po_grn_report.sin_report_template</field>
        <field name="report_file">visio_tti_pr_po_grn_report.sin_report_template</field>
        <field name="print_report_name">'Picking Report - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="visio_tti_pr_po_grn_report.paperformat_custom_purchaseorder"/>
    </record>
</odoo>