<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_device_attendance_tree" model="ir.ui.view">
        <field name="name">device.attendance.tree</field>
        <field name="model">device.attendance</field>
        <field name="arch" type="xml">
            <list  create="1" delete="0" edit="0" duplicate="0" export_xlsx="0" import="0">
                <field name="amt_seq_id"/>
                <field name="device_user_id"/>
                <field name="device_id_num"/>
                <field name="punching_time"/>
            </list>
        </field>
    </record>

    <record id="view_device_attendance_form" model="ir.ui.view">
        <field name="name">device.attendance.form</field>
        <field name="model">device.attendance</field>
        <field name="arch" type="xml">
            <form create="1" delete="0" edit="0" duplicate="0" export_xlsx="0" import="0">
                <group>
                    <field name="amt_seq_id"/>
                    <field name="device_user_id"/>
                    <field name="device_id_num"/>
                    <field name="punching_time"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_device_attendance" model="ir.actions.act_window">
        <field name="name">Device Attendance Logs</field>
        <field name="res_model">device.attendance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
