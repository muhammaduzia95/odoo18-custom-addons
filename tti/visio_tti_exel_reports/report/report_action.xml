<odoo>
    <record id="party_receivable_pdf_report_action" model="ir.actions.report">
        <field name="name">Party Receivable PDF</field>
        <field name="model">tti.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_exel_reports.party_receivable_report_pdf</field>
        <field name="report_file">visio_tti_exel_reports.party_receivable_report_pdf</field>
        <field name="binding_model_id" ref="visio_tti_exel_reports.model_tti_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <record id="paperformat_party_ledger" model="report.paperformat">
        <field name="name">Custom Party Ledger Format</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="party_ledger_pdf_report_action" model="ir.actions.report">
        <field name="name">Party Ledger PDF</field>
        <field name="model">tti.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_exel_reports.party_ledger_pdf_report</field>
        <field name="report_file">visio_tti_exel_reports.party_ledger_pdf_report</field>
        <field name="paperformat_id" ref="visio_tti_exel_reports.paperformat_party_ledger"/>
        <field name="binding_model_id" ref="visio_tti_exel_reports.model_tti_report_wizard"/>
        <field name="binding_type">report</field>

    </record>


</odoo>