<!--tti\visio_tti_exel_reports\wizard\sales_tax_report.xml-->
<odoo>

    <record id="view_sales_tax_report_tti_wizard" model="ir.ui.view">
        <field name="name">sales.tax.report.wizard.form</field>
        <field name="model">sales.tax.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Sales Tax Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="state_id"/>
<!--                        <field name="state_id" options="{'no_open': True}"/>-->
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_excel_report" type="object" string="Download Excel" class="btn-primary"/>
                    <button name="action_print_pdf_report" type="object" string="Download PDF" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sales_tax_report_tti_wizard" model="ir.actions.act_window">
        <field name="name">Sales Tax Report</field>
        <field name="res_model">sales.tax.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sales_tax_report_tti"
              name="Sales Tax Report"
              parent="visio_tti_exel_reports.menu_tti_eurofins_reports"
              action="action_sales_tax_report_tti_wizard"
              sequence="20"/>

</odoo>
