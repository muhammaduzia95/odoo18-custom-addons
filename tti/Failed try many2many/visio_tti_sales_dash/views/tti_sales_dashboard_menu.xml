<odoo>

    <!-- Client action for your dashboard -->
    <record id="action_tti_sales_dashboard" model="ir.actions.client">
        <field name="name">Sales Dashboard</field>
        <field name="tag">tti_dashboard_action</field>
    </record>

    <!-- Base top-level menu -->
    <menuitem id="menu_visio_tti_sales_dash_root"
              name="Dashboard"
              web_icon="spreadsheet_dashboard,static/description/icon.png"
              sequence="5"/>

    <!-- Dashboard menu item -->
    <menuitem id="menu_visio_tti_sales_dashboard"
              name="Dashboard"
              parent="menu_visio_tti_sales_dash_root"
              action="action_tti_sales_dashboard"
              sequence="1"/>

    <!-- Hiding the Dashboards Menu -->
    <data noupdate="0">

        <record id="group_dashboard_root_visible" model="res.groups">
            <field name="name">Dashboards Root Menu (Visible)</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('visio_tti_sales_dash.group_dashboard_root_visible')])]"/>
        </record>

    </data>


</odoo>
