<!-- CS Dashboard: Filters + KPI Cards -->
<templates xml:space="preserve">
  <t t-name="TTICSDashboardMain">
    <style>
      .card:hover {
        transform: translateY(-5px);
        box-shadow: 6px 6px 20px rgba(0, 0, 0, .35);
        cursor: pointer;
      }
    </style>

    <div class="o_action">
      <div class="o_content">
        <div class="container-fluid p-3">

          <!-- FILTERS (same layout as Sales Dashboard) -->
          <div class="row g-2 align-items-end">
            <!-- Date From -->
            <div class="col-md">
              <label>Date From</label>
              <input type="date"
                     class="form-control"
                     t-model="state.date_from"
                     t-on-change="onFilterChange" />
            </div>

            <!-- Date To -->
            <div class="col-md">
              <label>Date To</label>
              <input type="date"
                     class="form-control"
                     t-model="state.date_to"
                     t-on-change="onFilterChange" />
            </div>

            <!-- CS Personnel -->
            <div class="col-md">
              <label>CS Personnel</label>
              <select class="form-select"
                      t-model="state.selected_personnel"
                      t-on-change="onFilterChange">
                <t t-foreach="state.cs_personnel" t-as="p" t-key="p.id">
                  <option t-att-value="p.id"><t t-esc="p.name" /></option>
                </t>
              </select>
            </div>
          </div>

          <!-- KPI CARDS ROW -->
          <div class="row g-3 mt-4">
            <!-- Out Sourced Samples -->
            <div class="col-md-3">
              <div class="card text-center p-3"
                   style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);transition:all .3s ease-in-out;">
                <p class="fs-3 fw-bold mb-1">
                  <t t-esc="state.kpis.outsourced || 0" />
                </p>
                <h6 class="mb-0 text-muted">Out Sourced Samples</h6>
              </div>
            </div>

            <!-- Regular Samples -->
            <div class="col-md-3">
              <div class="card text-center p-3"
                   style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);transition:all .3s ease-in-out;">
                <p class="fs-3 fw-bold mb-1">
                  <t t-esc="state.kpis.regular || 0" />
                </p>
                <h6 class="mb-0 text-muted">Regular Samples</h6>
              </div>
            </div>

            <!-- Express Samples -->
            <div class="col-md-3">
              <div class="card text-center p-3"
                   style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);transition:all .3s ease-in-out;">
                <p class="fs-3 fw-bold mb-1">
                  <t t-esc="state.kpis.express || 0" />
                </p>
                <h6 class="mb-0 text-muted">Express Samples</h6>
              </div>
            </div>

            <!-- Shuttle Samples -->
            <div class="col-md-3">
              <div class="card text-center p-3"
                   style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);transition:all .3s ease-in-out;">
                <p class="fs-3 fw-bold mb-1">
                  <t t-esc="state.kpis.shuttle || 0" />
                </p>
                <h6 class="mb-0 text-muted">Shuttle Samples</h6>
              </div>
            </div>
          </div>

          <!-- BELOW KPI CARDS -->
          <div class="row g-3 mt-4">

            <!-- LEFT Donut Chart -->
            <div class="col-lg-4 col-md-12">
              <div class="card p-3 text-center"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:700px;">
                <h5 class="mb-2 text-muted">Reports Delivery Status</h5>
                <canvas id="left_donut_chart" style="width:100%; height:220px;"></canvas>
              </div>
            </div>

            <!-- MIDDLE SECTION -->
            <div class="col-lg-4 col-md-12 d-flex flex-column">
              <!-- Upper Div: Daily Summary Table -->
              <div class="card p-3 mb-3 flex-grow-1"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);">
                <div class="table-responsive">
                  <table class="table table-sm mb-0 text-center align-middle">
                    <thead class="table-light">
                      <tr>
                        <th></th>
                        <th>Today</th>
                        <th>Yesterday</th>
                        <th>Day Before Yesterday</th>
                      </tr>
                    </thead>
                    <tbody>
                      <t t-foreach="state.kpis.daily_table || []" t-as="row" t-key="row.name">
                        <tr>
                          <td style="text-align:left; font-weight:600;">
                            <t t-esc="row.name" />
                          </td>
                          <td><t t-esc="row.today" /></td>
                          <td><t t-esc="row.yesterday" /></td>
                          <td><t t-esc="row.day_before" /></td>
                        </tr>
                      </t>
                      <t t-if="!(state.kpis.daily_table &amp;&amp; state.kpis.daily_table.length)">
                        <tr>
                          <td colspan="4" class="text-muted text-center">No data available</td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- Bottom Div: Bar Chart -->
              <div class="card p-3 flex-grow-1"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:250px;">
                <canvas id="middle_bar_chart" style="width:100%; height:250px;"></canvas>
              </div>
            </div>

            <!-- RIGHT Donut Chart -->
            <div class="col-lg-4 col-md-12">
              <div class="card p-3 text-center"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:700px;">
                <h5 class="mb-2 text-muted">Sale Order Status</h5>
                <canvas id="right_donut_chart" style="width:100%; height:320px;"></canvas>
              </div>
            </div>

          </div>

          <!-- ============ SALES PERSONNEL SNAPSHOT (5 per row) ============ -->
          <style>
            .five-grid {
              display: grid;
              grid-template-columns: repeat(5, 1fr);
              gap: 12px;
              height: 200px;

            }
            @media (max-width: 1400px) { .five-grid { grid-template-columns: repeat(4, 1fr);} }
            @media (max-width: 1200px) { .five-grid { grid-template-columns: repeat(3, 1fr);} }
            @media (max-width: 992px)  { .five-grid { grid-template-columns: repeat(2, 1fr);} }
            @media (max-width: 576px)  { .five-grid { grid-template-columns: 1fr;} }
          </style>

          <div class="row g-3 mt-4">
            <div class="col-12">
              <div class="five-grid">
                <t t-foreach="state.kpis.person_cards || []" t-as="p" t-key="p.user_id">
                  <div class="card p-3 text-center"
                       style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);height:320px;">
                    <h6 class="mb-2"><t t-esc="p.name"/></h6>
                    <canvas t-att-id="'sp_donut_' + p.user_id" style="width:100%; height:240px;"></canvas>
                  </div>
                </t>
                <t t-if="!(state.kpis.person_cards &amp;&amp; state.kpis.person_cards.length)">
                  <div class="card p-4 text-center text-muted"
                       style="background:#fff;border:none;border-radius:6px;box-shadow:2px 2px 15px rgba(0,0,0,.25);">
                    No personnel data for the chosen filters
                  </div>
                </t>
              </div>
            </div>
          </div>



        </div>
      </div>
    </div>
  </t>
</templates>


