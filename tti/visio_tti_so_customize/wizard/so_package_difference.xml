<odoo>
    <record id="view_so_package_difference_wizard" model="ir.ui.view">
        <field name="name">so.package.difference.wizard.form</field>
        <field name="model">so.package.difference.wizard</field>
        <field name="arch" type="xml">
            <form string="SO Package Difference">
                <group>
                    <group>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" string="Print" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_so_package_difference_wizard" model="ir.actions.act_window">
        <field name="name">SO Package Difference</field>
        <field name="res_model">so.package.difference.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="report_so_package_difference_excel" model="ir.actions.report">
        <field name="name">SO Package Difference</field>
        <field name="model">so.package.difference.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">visio_tti_so_customize.so_package_difference_xlsx</field>
        <field name="report_file">visio_tti_so_customize.so_package_difference_xlsx</field>
        <field name="binding_type">report</field>
    </record>

</odoo>