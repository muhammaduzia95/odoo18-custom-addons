<odoo>
    <data noupdate="1">
        <!-- Sale Order Sequence -->
        <record id="seq_sale_order" model="ir.sequence">
            <field name="name">Sale Order</field>
            <field name="code">sale.order.sequence</field>
            <field name="prefix">SO</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="api_global_unique_id_sequence" model="ir.sequence">
            <field name="name">API Global Unique Numeric ID</field>
            <field name="code">api.global.unique.id</field>
            <field name="prefix"></field>
            <field name="padding">0</field>
            <field name="number_next">30000</field>
            <field name="number_increment">1</field>
        </record>

        <record id="new_api_global_unique_id_sequence" model="ir.sequence">
            <field name="name">New API Global Unique Numeric ID</field>
            <field name="code">new.api.global.unique.id</field>
            <field name="prefix"></field>
            <field name="padding">0</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>