<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tti city zone -->
        <record id="view_tti_city_zone_tree" model="ir.ui.view">
            <field name="name">tti.city.zone.list</field>
            <field name="model">tti.city.zone</field>
            <field name="arch" type="xml">
                <list string="City Zone" editable="bottom">
                    <field name="code" optional="hide" readonly="1"/>
                    <field name="name"/>
                    <field name="tti_city_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="company_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tti_city_zone_form" model="ir.ui.view">
            <field name="name">tti.city.zone.form</field>
            <field name="model">tti.city.zone</field>
            <field name="arch" type="xml">
                <form string="City Zone">
                    <sheet>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="name"/>
                            <field name="tti_city_id" options='{"no_open": True, "no_create": True}'
                                   domain="[('company_id', '=', company_id)]"/>
                            <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tti_city_zone_search" model="ir.ui.view">
            <field name="name">tti.city.zone.search</field>
            <field name="model">tti.city.zone</field>
            <field name="arch" type="xml">
                <search string="City Zone">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="tti_city_id"/>
                    <group string="Group By">
                        <filter name="groupby_city_id" string="City" context="{'group_by': 'tti_city_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tti_city_zone" model="ir.actions.act_window">
            <field name="name">City Zone</field>
            <field name="res_model">tti.city.zone</field>
            <field name="view_id" ref="view_tti_city_zone_tree"/>
            <field name="domain">['|', ('company_id', '=', False), ('company_id', 'in', allowed_company_ids)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a city zone
                </p>
                <p>
                </p>
            </field>
        </record>

    </data>
</odoo>
