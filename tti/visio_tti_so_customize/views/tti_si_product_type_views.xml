<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_tti_si_product_type_tree" model="ir.ui.view">
            <field name="name">tti.si.product.type.list</field>
            <field name="model">tti.si.product.type</field>
            <field name="arch" type="xml">
                <list string="Product Type" editable="bottom">
                    <field name="name"/>
                    <field name="tti_si_category" options="{'no_create': True, 'no_open': True}" />
                    <field name="company_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tti_si_product_type_form" model="ir.ui.view">
            <field name="name">tti.si.product.type.form</field>
            <field name="model">tti.si.product.type</field>
            <field name="arch" type="xml">
                <form string="Product Type">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="tti_si_category" options="{'no_create': True, 'no_open': True}" domain="[('company_id', '=', company_id)]"/>
                            <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tti_si_product_type_search" model="ir.ui.view">
            <field name="name">tti.si.product.type.search</field>
            <field name="model">tti.si.product.type</field>
            <field name="arch" type="xml">
                <search string="Product Type">
                    <field name="name"/>
                    <group string="Group By">
                        <filter name="groupby_company_id" string="Company" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tti_si_product_type" model="ir.actions.act_window">
            <field name="name">Product Type</field>
            <field name="res_model">tti.si.product.type</field>
            <field name="view_id" ref="view_tti_si_product_type_search"/>
            <field name="domain">['|', ('company_id', '=', False), ('company_id', 'in', allowed_company_ids)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a product type
                </p>
                <p> </p>
            </field>
        </record>

    </data>
</odoo>
