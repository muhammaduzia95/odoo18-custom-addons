<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Editable Tree/List View -->
    <record id="view_target_achieve_tree" model="ir.ui.view">
        <field name="name">target.achieve.tree</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="region" options="{'no_create': True, 'no_open': True}"/>
                <field name="city_zones" options="{'no_create': True, 'no_open': True}"/>
                <field name="categories" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
<!--                <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>-->
                <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="target"/>
                <field name="company_id" optional="hide" options="{'no_create': True, 'no_open': True}"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_target_achieve_form" model="ir.ui.view">
        <field name="name">target.achieve.form</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="region" options="{'no_create': True, 'no_open': True}"/>
                        <field name="city_zones" options="{'no_create': True, 'no_open': True}"/>
                        <field name="categories" widget="many2many_tags"
                               options="{'no_create': True, 'no_open': True}"/>
<!--                        <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>-->
                        <field name="employee_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="target"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_target_achieve_search" model="ir.ui.view">
        <field name="name">target.achieve.search</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <search string="Target Achieved">
                <field name="name" string="Target"/>
                <field name="partner_id"/>
                <field name="employee_id"/>

                <group string="Group By">
                    <filter name="partner" string="Partner" context="{'group_by':'partner_id'}"/>
                    <filter name="employee" string="Employee" context="{'group_by':'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action + Menu -->
    <record id="action_target_achieve" model="ir.actions.act_window">
        <field name="name">Targets Achieved</field>
        <field name="res_model">target.achieve</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_target_achieve_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create targets for employees or partners here.
            </p>
        </field>
    </record>

</odoo>
