<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_tti_parcel_courier_tree" model="ir.ui.view">
            <field name="name">tti.parcel.courier.list</field>
            <field name="model">tti.parcel.courier</field>
            <field name="arch" type="xml">
                <list string="Parcel Courier" editable="bottom">
                    <field name="name"/>
                    <field name="company_id" options="{'no_create': True, 'no_open': True}" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_tti_parcel_courier_form" model="ir.ui.view">
            <field name="name">tti.parcel.courier.form</field>
            <field name="model">tti.parcel.courier</field>
            <field name="arch" type="xml">
                <form string="Parcel Courier">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tti_parcel_courier_search" model="ir.ui.view">
            <field name="name">tti.parcel.courier.search</field>
            <field name="model">tti.parcel.courier</field>
            <field name="arch" type="xml">
                <search string="Parcel Courier">
                    <field name="name"/>
                    <group string="Group By">
                        <filter name="groupby_company_id" string="Company" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tti_parcel_courier" model="ir.actions.act_window">
            <field name="name">Parcel Courier</field>
            <field name="res_model">tti.parcel.courier</field>
            <field name="view_id" ref="view_tti_parcel_courier_tree"/>
            <field name="domain">['|', ('company_id', '=', False), ('company_id', 'in', allowed_company_ids)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a Parcel Courier
                </p>
                <p> </p>
            </field>
        </record>

    </data>
</odoo>
