<odoo>
    <record id="view_product_pricelist_form_custom" model="ir.ui.view">
        <field name="name">product.product.pricelist.form.custom</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='item_ids']/list/field[@name='price']" position="after">
                <field name="dollar_rate"/>
            </xpath>
        </field>
    </record>

    <record id="view_pricelist_item_form_inherit_dollar_price" model="ir.ui.view">
        <field name="name">product.pricelist.item.form.inherit.dollar.price</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[1]" position="after">
                <field name="dollar_rate"/>
            </xpath>
        </field>
    </record>
</odoo>
