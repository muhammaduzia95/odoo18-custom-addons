<odoo>
    <data>
        <record id="action_quotations_custom_tti" model="ir.actions.act_window">
            <field name="name">Quotations</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="domain">[("state","in",["draft","sent","quotation_done"])]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation
                </p>
            </field>
        </record>

        <record id="action_sale_order_custom_tti" model="ir.actions.act_window">
            <field name="name">Sale Orders</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
            <field name="domain">[("state","not in",["draft","sent"])]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new quotation
                </p>
            </field>
        </record>

