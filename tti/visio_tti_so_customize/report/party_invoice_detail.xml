<odoo>
    <template id="party_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="text-align: center; border-bottom:1px solid black; margin-bottom:20px;">
                            <h3>Party Invoice Detail</h3>
                            <p>
                                <strong>From Date:</strong>
                                <t t-esc="docs.date_from"/>
                                <strong style="margin-left:30px;">To Date:</strong>
                                <t t-esc="docs.date_to"/>
                            </p>
                        </div>

                        <table class="table table-sm"
                               style="width:100%; font-size:11px; border: 1px solid black; border-collapse: collapse; margin-top: 10px;">
                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Company Name :</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <t t-esc="manufacturer.name"/>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Buyer Name :</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <t t-esc="buyer.name if buyer else 'N/A'"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Contact Person :</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <!--                                    <t t-esc="manufacturer.contact_name or ''"/>-->
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>%</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;"></td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Cell Number :</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <t t-esc="manufacturer.phone or manufacturer.mobile"/>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;" colspan="2">Sales Tax With Holding
                                    Agent
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>Email Address:</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <t t-esc="manufacturer.email or ''"/>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;" colspan="2">Income Tax With Holding
                                    Agent
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <strong>NTN:</strong>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;">
                                    <t t-esc="manufacturer.vat or ''"/>
                                </td>
                                <td style="border: 1px solid black; padding: 5px;" colspan="2"></td>
                            </tr>
                        </table>

                        <br/>
                        <h4 style="margin-top: 15px;">Invoice List</h4>
                        <table style="width:100%; font-size:11px; border: 1px solid black; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th style="border: 1px solid black; padding: 3px;">Sr #</th>
                                    <th style="border: 1px solid black; padding: 3px;">Date</th>
                                    <th style="border: 1px solid black; padding: 3px;">Invoice #</th>
                                    <th style="border: 1px solid black; padding: 3px;">Reference #</th>
                                    <th style="border: 1px solid black; padding: 3px;">Agent</th>
                                    <th style="border: 1px solid black; padding: 3px;">Description</th>
                                    <th style="border: 1px solid black; padding: 3px;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sr" t-value="1"/>
                                <t t-foreach="sale_orders" t-as="so">
                                    <t t-foreach="so.invoice_ids"
                                       t-as="inv">
                                        <tr>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="sr"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="so.date_order"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="inv.name"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="so.name"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="so.tti_pi_agent_id.name"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px;">
                                                <t t-esc="so.tti_si_description"/>
                                            </td>
                                            <td style="border: 1px solid black; padding: 3px; text-align: right;">
                                                <t t-esc="inv.amount_total"/>
                                            </td>
                                        </tr>
                                        <t t-set="sr" t-value="sr + 1"/>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>

            </t>
        </t>
    </template>

    <record id="paperformat_custom_saleorder" model="report.paperformat">
        <field name="name">Custom Sale Order Format</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">55</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <record id="report_party_invoice_detail_pdf" model="ir.actions.report">
        <field name="name">Party Invoice Detail</field>
        <field name="model">party.invoice.detail.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">visio_tti_so_customize.party_invoice_template</field>
        <field name="report_file">visio_tti_so_customize.party_invoice_template</field>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="visio_tti_so_customize.paperformat_custom_saleorder"/>
    </record>

</odoo>
