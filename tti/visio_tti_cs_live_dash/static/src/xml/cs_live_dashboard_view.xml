<?xml version="1.0" encoding="UTF-8"?>
<!--D:\Visiomate\Odoo\odoo18\custom_addons\tti\visio_tti_cs_dash\static\src\xml\cs_live_dashboard_view.xml-->


<templates xml:space="preserve">
  <t t-name="TTICSLiveDashboardMain">
    <div class="o_action">
      <div class="o_content">
        <div class="container-fluid p-3">

          <!-- FILTERS -->
          <div class="row g-3 align-items-end mb-4">
            <div class="col-md-3">
              <label>Date From</label>
              <input type="date" class="form-control"
                     t-model="state.date_from"
                     t-on-change="onFilterChange"/>
            </div>

            <div class="col-md-3">
              <label>Date To</label>
              <input type="date" class="form-control"
                     t-model="state.date_to"
                     t-on-change="onFilterChange"/>
            </div>
          </div>

          <!-- CURRENT DATE/TIME ROW (dynamic) -->
          <div class="row mb-3">
            <div class="col-12 text-center">
              <h6 class="fw-semibold text-muted" style="letter-spacing:0.5px;">
                <t t-esc="state.now"/>
              </h6>
            </div>
          </div>

          <!-- DASHBOARD CONTENT -->
          <div class="row g-3 mt-3">

            <!-- LEFT DIV -->
            <div class="col-lg-6 col-md-12 d-flex flex-column">

              <!-- Top Card -->
              <div class="card p-3 mb-3 flex-grow-1"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:300px;">
                <h6 class="mb-2 text-muted text-center">Report Delivery Status</h6>
                <div style="height:240px;">
                  <canvas id="live_left_donut" style="width:100%; height:240px;"></canvas>
                </div>
              </div>

              <!-- Bottom Card: Reports Due Today (Table) -->
              <div class="card p-3 flex-grow-1"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:300px;">
                <h6 class="mb-2 text-muted text-center">Reports Due Today</h6>

                <div class="table-responsive" style="max-height:230px; overflow:auto;">
                  <table class="table table-sm mb-0 align-middle text-center">
                    <thead class="table-light">
                      <tr>
                        <th style="width:70px;">Sr.No.</th>
                        <th style="text-align: left;">Report No.</th>
                        <th style="width:160px;">Due In</th>
                      </tr>
                    </thead>
                    <tbody>
                      <t t-if="state.due_today &amp;&amp; state.due_today.length">
                        <t t-foreach="state.due_today" t-as="r" t-key="r.sr">
                          <tr>
                            <td><t t-esc="r.sr"/></td>
                            <td class="text-start"><t t-esc="r.report_no"/></td>
                            <td><t t-esc="r.due_in"/></td>
                          </tr>
                        </t>
                      </t>
                      <t t-if="!(state.due_today &amp;&amp; state.due_today.length)">
                        <tr>
                          <td colspan="3" class="text-muted">No reports due today</td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </div>
              </div>

            </div>

            <!-- RIGHT DIV -->
            <div class="col-lg-6 col-md-12">
              <div class="card p-3"
                   style="background:#fff;border:none;border-radius:6px;
                          box-shadow:2px 2px 15px rgba(0,0,0,.25);height:620px;">
                <h6 class="mb-2 text-muted text-center">Daily Requisition Summary</h6>
                <div class="table-responsive" style="max-height:560px; overflow:auto;">
                  <table class="table table-sm mb-0 align-middle text-center">
                    <thead class="table-light">
                      <tr>
                        <th style="width:70px;">Sr. No.</th>
                        <th>Name</th>
                        <th style="width:140px;">Parcel Assigned</th>
                        <th style="width:120px;">Open Parcels</th>
                        <th style="width:120px;">Reports Due</th>
                        <th style="width:160px;">Reports Delivered</th>
                      </tr>
                    </thead>
                    <tbody>
                      <t t-if="state.right_rows &amp;&amp; state.right_rows.length">
                        <t t-foreach="state.right_rows" t-as="r" t-key="r.sr">
                          <tr>
                            <td><t t-esc="r.sr"/></td>
                            <td class="text-start"><t t-esc="r.name"/></td>
                            <td><t t-esc="r.parcel_assigned"/></td>
                            <td><t t-esc="r.open_parcels"/></td>
                            <td><t t-esc="r.reports_due"/></td>
                            <td><t t-esc="r.reports_delivered"/></td>
                          </tr>
                        </t>
                      </t>
                      <t t-if="!(state.right_rows &amp;&amp; state.right_rows.length)">
                        <tr>
                          <td colspan="6" class="text-muted">No activity today</td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </t>
</templates>

