<odoo>
    <record id="view_hr_contract_form_inherit_mess_deduction" model="ir.ui.view">
        <field name="name">hr.contract.form.mess.deduction</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='information']/group[@name='salary_info']/group[@name='salary']/div[@name='wage']"
                   position="after">
                <field name="mess_deduction" class="oe_inline"/>
                <field name="tax_deduction" class="oe_inline"/>
                <field name="medical_allowance_tti" class="oe_inline"/>
                <field name="gross_salary_tti" class="oe_inline"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Probation" name="probation_page"
                      invisible="not show_probation_tab">
                    <group>
                        <group>
                            <button name="action_send_probation_notification"
                                    string="Send Probation Reminder"
                                    type="object"
                                    class="btn-primary"/>
                        </group>
                    </group>

                    <separator string="Probation Checklist"/>
                    <field name="probation_checklist"
                           widget="html"
                           placeholder="Enter probation checklist items and notes here..."
                           options="{'style-inline': true, 'resizable': true}"/>
                </page>
            </xpath>
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="show_probation_tab" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_contract_form_inherit_custom" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.custom</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_payroll_account.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='contract_details']/group" position="replace">
                <group>
                    <seprator string="Accounting"/>
                    <field name="analytic_dist" widget="analytic_distribution"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
