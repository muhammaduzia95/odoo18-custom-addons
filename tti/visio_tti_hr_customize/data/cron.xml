<odoo>
    <data noupdate="1">
        <record id="ir_cron_create_portal_users_for_employees" model="ir.cron">
            <field name="name">Create Portal Users for Employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.create_portal_users_for_employees()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">False</field>
        </record>

        <record id="ir_cron_probation_reminder" model="ir.cron">
            <field name="name">Send Probation Reminders</field>
            <field name="model_id" ref="hr_contract.model_hr_contract"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_probation_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
