<!--D:\Visiomate\Odoo\odoo18\custom_addons\tti\visio_tti_report_sending\security\send_report_groups.xml-->

<odoo>

    <!-- Category for grouping these access rights -->
    <record id="module_category_report_sending_rights" model="ir.module.category">
        <field name="name">Report Sending Rights</field>
        <field name="description">Access rights for Send Report functionality in Sale Orders</field>
        <field name="sequence">30</field>
    </record>

    <!-- Manager Group -->
    <record id="group_sale_order_send_report_manager" model="res.groups">
        <field name="name">Send Report Manager</field>
        <field name="category_id" ref="module_category_report_sending_rights"/>
    </record>

    <!-- User Group -->
    <record id="group_sale_order_send_report_user" model="res.groups">
        <field name="name">Send Report User</field>
        <field name="category_id" ref="module_category_report_sending_rights"/>
    </record>


</odoo>
