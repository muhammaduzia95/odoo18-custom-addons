<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--list view for requisition order-->
    <record id="requisition_order_view_list" model="ir.ui.view">
        <field name="name">requisition.order.view.list</field>
        <field name="model">requisition.order</field>
        <field name="arch" type="xml">
            <list editable="bottom"  delete="0 if state not in ['new','waiting_department_approval','waiting_head_approval'] else 1">
                <field name="state" column_invisible="True"/>
                <field name="company_id" column_invisible="1"/>
                <field name="requisition_type" column_invisible="1"
                       groups="visio_tti_emp_purchase_requisition.employee_requisition_head,visio_tti_emp_purchase_requisition.employee_requisition_manager"/>
                <field name="partner_id" domain="[('tti_company_category', '=', 'default'),('company_id', '=', company_id)]" options="{'no_create': True, 'no_open': True}"
                       invisible="requisition_type != 'purchase_order'"
                       groups="visio_tti_emp_purchase_requisition.employee_requisition_head,visio_tti_emp_purchase_requisition.employee_requisition_manager"/>
                <field name="product_id" domain="[('purchase_ok', '=', True)]" options="{'no_create': True, 'no_open': True}"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="uom" options="{'no_create': True, 'no_open': True}" column_invisible="1"/>
                <field name="product_uom" options="{'no_create': True, 'no_open': True}"/>
            </list>
        </field>
    </record>
</odoo>