<odoo>
    <record id="view_parcel_cities_tree" model="ir.ui.view">
        <field name="name">parcel.cities.tree</field>
        <field name="model">parcel.cities</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>

    <record id="action_parcel_cities" model="ir.actions.act_window">
        <field name="name">Parcel Cities</field>
        <field name="res_model">parcel.cities</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_parcel_cities_tree"/>
        <field name="target">current</field>
    </record>

    <record id="view_tti_parcels_form_inherit_parcel_city" model="ir.ui.view">
        <field name="name">tti.parcels.form.inherit.parcel.city</field>
        <field name="model">tti.parcels</field>
        <field name="inherit_id" ref="visio_tti_so_customize.view_tti_parcels_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tti_city_id']" position="replace">
                <field name="parcel_city_id" readonly="state != 'draft'" string="City"
                       options="{'no_edit': False, 'no_open': True, 'no_create': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_tti_parcels_list_inherit_parcel_city" model="ir.ui.view">
        <field name="name">tti.parcels.list.inherit.parcel.city</field>
        <field name="model">tti.parcels</field>
        <field name="inherit_id" ref="visio_tti_so_customize.view_tti_parcels_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tti_city_id']" position="replace">
                <field name="parcel_city_id" readonly="state != 'draft'" string="City"
                       options="{'no_edit': False, 'no_open': True, 'no_create': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_tti_parcels_search_inherit_parcel_city" model="ir.ui.view">
        <field name="name">tti.parcels.list.inherit.parcel.city</field>
        <field name="model">tti.parcels</field>
        <field name="inherit_id" ref="visio_tti_so_customize.view_tti_parcels_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tti_city_id']" position="replace">
                <field name="parcel_city_id"/>
            </xpath>
            <xpath expr="//filter[@name='groupby_tti_city_id']" position="replace">
                 <filter name="groupby_parcel_city_id" string="City" context="{'group_by': 'parcel_city_id'}"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_tti_parcels_config" parent="visio_tti_so_customize.menu_tti_parcels_root" name="Configuration"
              sequence="20" groups="visio_tti_so_customize.group_delete_parcels">
        <menuitem id="menu_tti_parcel_courier" name="Parcel Courier" sequence="10"
                  action="visio_tti_so_customize.action_tti_parcel_courier"/>
        <menuitem id="menu_parcel_cities" name="Parcels Cities"
                  action="action_parcel_cities" sequence="20"/>
    </menuitem>
</odoo>