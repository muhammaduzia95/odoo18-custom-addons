<odoo>
    <record id="view_account_multi_payments_form" model="ir.ui.view">
        <field name="name">account.multi.payments.form</field>
        <field name="model">account.multi.payments</field>
        <field name="arch" type="xml">
            <form string="Multi Payments" delete="0">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"
                            invisible="state == 'posted'"/>
                    <button name="action_reverse" string="Reverse" invisible="state == 'draft' or is_reversed"
                            type="object" class="btn-primary"/>
                    <!--                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"/>-->
                    <!--                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" class="btn-secondary"-->
                    <!--                            invisible="state == 'draft'"/>-->
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Smart Button: View Payments -->
                        <button name="action_view_payments"
                                string="Payments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money">
                        </button>
                        <button type="object"
                                string="Invoices"
                                name="action_view_invoices"
                                class="oe_stat_button"
                                icon="fa-file-text">
                        </button>

                    </div>
                    <widget name="web_ribbon" title="Posted" invisible="state != 'posted' or is_reversed"
                            bg_color="text-bg-success"/>
                    <widget name="web_ribbon" title="Reversed" invisible="not is_reversed" bg_color="text-bg-danger"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="payment_type" widget="radio" options="{'horizontal': True}"
                                   readonly="1"/>
                            <field name="payment_mode" widget="selection" required="1" readonly="state == 'posted'"/>
                            <field name="is_reversed" widget="toggle_boolean" readonly="1"/>
                            <field name="partner_id" string="Customer" widget="res_partner_many2one"
                                   invisible="payment_type == 'outbound'"
                                   context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}"
                                   readonly="state == 'posted'"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   domain="[('company_id', '=', company_id)]"
                            />
                            <field name="partner_id" string="Vendor" widget="res_partner_many2one"
                                   context="{'res_partner_search_mode': 'supplier', 'show_address': 1, 'show_vat': True}"
                                   invisible="payment_type == 'inbound'"
                                   readonly="state == 'posted'"
                                   domain="[('company_id', '=', company_id)]"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"/>
                            <field name="sale_tax" readonly="state == 'posted'"/>
                            <field name="amount" string="Net Amount"
                                   force_save="1"
                                   readonly="state == 'posted' or payment_mode == 'advance' "/>
                            <field name="gross_amount" readonly="1" force_save="1"/>
                            <field name="currency_id" readonly="state == 'posted'"/>
                            <field name="payment_method_id" readonly="state == 'posted'"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   domain="[('id', 'in', available_payment_method_line_ids)]"/>
                            <field name="partner_bank_id" string="Company Bank Account"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   invisible="payment_type == 'outbound'"
                                   readonly="state == 'posted'"
                                   domain="[('id', 'in', available_partner_bank_ids)]"/>
                            <field name="partner_bank_id" string="Vendor Bank Account"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   invisible="payment_type == 'inbound'"
                                   readonly="state == 'posted'"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'posted'"/>
                            <field name="company_id" readonly="1"/>
                            <field name="memo" readonly="state == 'posted'"/>
                            <field name="advance_payment_ids" widget="many2many_tags"
                                   domain="[('partner_id', '=', partner_id), ('invoice_ids', '=', False), ('state', '=', 'paid')]"
                                   readonly="state == 'posted'"
                                   options="{'no_create': True}"
                                   invisible="payment_mode == 'simple'"/>
                            <field name="advance_payment_total" invisible="payment_mode == 'simple'"/>
                            <field name="journal_id" readonly="state == 'posted'"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   domain="[('id', 'in', available_journal_ids),('company_id', '=', company_id)]"/>
                            <field name="move_type" invisible="1"/>
                            <field name="global_wh" readonly="state == 'posted'"/>
                            <field name="sale_wh_tax" readonly="state == 'posted'"/>
                            <field name="income_wh_tax" readonly="state == 'posted'"/>
                            <field name="sale_wh_tax_account"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   readonly="state == 'posted'"
                                   domain="[('account_type', '=', move_type=='out_invoice' and 'asset_current' or 'liability_current'), ('company_ids', 'in', company_id)]"/>
                            <field name="income_wh_tax_account"
                                   options="{'no_open': True,'no_create': True,'no_edit': True}"
                                   readonly="state == 'posted'"
                                   domain="[('account_type', '=', move_type=='out_invoice' and 'asset_current' or 'liability_current'), ('company_ids', 'in', company_id)]"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Customer Invoices" invisible="payment_type == 'outbound'">
                            <div class="d-flex gap-2">
                                <button name="action_delete_unselected_lines" type="object"
                                        string="Delete Other Records" class="btn-danger mr-2"
                                        invisible="state == 'posted'"/>
                                <button name="action_compute_withholding" type="object"
                                        string="Compute With Holding" class="btn-success ml-2"
                                        invisible="state == 'posted'"/>
                            </div>
                            <field name="account_multi_payment_line_ids" readonly="state == 'posted'">
                                <list editable="bottom">
                                    <field name="selected" widget="boolean_toggle"/>
                                    <field name="name" optional="hide"/>
                                    <field name="invoice_id"
                                           options="{'no_open': False,'no_create': True,'no_edit': True}"/>
                                    <field name="payment_ids"
                                           options="{'no_open': True,'no_create': True,'no_edit': True}" readonly="1"
                                           widget="many2many_tags" optional="show"/>
                                    <field name="payment_name" optional="hide"/>
                                    <field name="currency_id" readonly="1"/>
                                    <field name="sale_wh_tax" readonly="False"/>
                                    <field name="income_wh_tax" readonly="False"/>
                                    <field name="sale_wh_tax_amount"/>
                                    <field name="income_wh_tax_amount"/>
                                    <field name="amount" sum="To Pay"/>
                                    <field name="to_pay_amount_tax" readonly="1"/>
                                    <field name="total_pay_amount" sum="Total Pay Amount" readonly="1"/>
                                    <field name="invoice_date" optional="show"/>
                                    <field name="amount_tax" readonly="1"/>
                                    <field name="amount_untaxed" readonly="1"/>
                                    <field name="due_date" optional="hide"/>
                                    <field name="invoice_amount"/>
                                    <field name="residual_amount"/>
                                    <field name="status_in_payment" widget="badge"
                                           decoration-danger="status_in_payment == 'not_paid'"
                                           decoration-warning="status_in_payment == 'partial'"
                                           decoration-success="status_in_payment == 'paid'"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_invoice_amount" readonly="1"/>
                                <field name="total_residual_amount" readonly="1"/>
                                <field name="total_tax_amount" readonly="1"/>
                                <field name="total_untaxed_amount" readonly="1"/>
                                <field name="total_sale_wh_tax" readonly="1"/>
                                <field name="total_income_wh_tax" readonly="1"/>
                                <field name="total_to_pay" readonly="1"/>
                                <field name="total_pay_amount" readonly="1"/>
                                <field name="access_payment" readonly="1"/>
                            </group>
                        </page>
                        <page string="Vendor Bills" invisible="payment_type == 'inbound'">
                            <button name="action_delete_unselected_lines" type="object"
                                    string="Delete Other Records" class="btn-danger"
                                    invisible="state == 'posted'"/>
                            <field name="account_multi_payment_line_ids" readonly="state == 'posted'">
                                <list editable="bottom">
                                    <field name="selected" widget="boolean_button"/>
                                    <field name="name" optional="hide"/>
                                    <field name="invoice_id" optional="show"/>
                                    <field name="payment_ids" widget="many2many_tags" optional="show"/>
                                    <field name="payment_name" optional="show"/>
                                    <field name="currency_id" readonly="1"/>
                                    <field name="sale_wh_tax" readonly="False"/>
                                    <field name="income_wh_tax" readonly="False"/>
                                    <field name="sale_wh_tax_amount"/>
                                    <field name="income_wh_tax_amount"/>
                                    <field name="amount"/>
                                    <field name="total_pay_amount" readonly="0"/>
                                    <field name="amount_tax"/>
                                    <field name="amount_untaxed"/>
                                    <field name="invoice_date" optional="show"/>
                                    <field name="due_date" optional="show"/>
                                    <field name="invoice_amount"/>
                                    <field name="residual_amount"/>
                                    <field name="status_in_payment" widget="badge"
                                           optional="show"
                                           decoration-danger="status_in_payment == 'not_paid'"
                                           decoration-warning="status_in_payment == 'partial'"
                                           decoration-success="status_in_payment == 'paid'"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_invoice_amount" readonly="1"/>
                                <field name="total_residual_amount" readonly="1"/>
                                <field name="total_tax_amount" readonly="1"/>
                                <field name="total_untaxed_amount" readonly="1"/>
                                <field name="total_sale_wh_tax" readonly="1"/>
                                <field name="total_income_wh_tax" readonly="1"/>
                                <field name="total_to_pay" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_multi_payments_list" model="ir.ui.view">
        <field name="name">account.multi.payments.list</field>
        <field name="model">account.multi.payments</field>
        <field name="arch" type="xml">
            <list delete="0" decoration-danger="is_reversed" decoration-info="state == 'draft'"
                  decoration-success="state == 'posted'">
                <field name="name"/>
                <field name="payment_type"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="is_reversed" widget="toggle_boolean"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"/>
            </list>
        </field>
    </record>

    <record id="action_account_multi_payments_customer" model="ir.actions.act_window">
        <field name="name">Multi Payments (Customers)</field>
        <field name="res_model">account.multi.payments</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_payment_type': 'inbound'}</field>
        <field name="domain">[('payment_type', '=', 'inbound')]</field>
    </record>

    <record id="action_account_multi_payments_vendor" model="ir.actions.act_window">
        <field name="name">Multi Payments (Vendors)</field>
        <field name="res_model">account.multi.payments</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_payment_type': 'outbound'}</field>
        <field name="domain">[('payment_type', '=', 'outbound')]</field>
    </record>


    <!-- Customers Menu -->
    <menuitem id="menu_account_multi_payments_customer"
              name="Multi Payments"
              parent="account.menu_finance_receivables"
              action="action_account_multi_payments_customer"
              sequence="50"/>

    <!-- Vendors Menu -->
    <menuitem id="menu_account_multi_payments_vendor"
              name="Multi Payments"
              parent="account.menu_finance_payables"
              action="action_account_multi_payments_vendor"
              sequence="50"/>

</odoo>
