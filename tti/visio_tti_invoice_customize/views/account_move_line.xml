<odoo>
    <record id="view_move_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.custom.field</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_unit']" position="after">
<!--                <field name="is_vendor_bill"/>-->
                <field name="price_unit_rate" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>