<odoo>
    <record id="view_account_payment_form_inherit_multi_payment" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.multi.payment</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[@name='main_group']/group[@name='group2']" position="inside">
                <field name="multi_payment_id" invisible="not multi_payment_id" readonly="multi_payment_id"/>
            </xpath>
            <xpath expr="//sheet/group[@name='main_group']/group[@name='group2']/field[@name='partner_bank_id']" position="after">
                <field name="po_ref" invisible="payment_type != 'outbound'"/>
            </xpath>
        </field>
    </record>

</odoo>