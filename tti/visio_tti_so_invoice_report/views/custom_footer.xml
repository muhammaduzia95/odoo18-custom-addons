<odoo>
    <template id="tti_custom_footer">
        <div t-attf-class="footer o_company_#{company.id}_layout"
             style="font-size: 10px; border-top: 1px solid black; padding-top: 10px;">

            <!-- Top: 3 Columns Section -->
