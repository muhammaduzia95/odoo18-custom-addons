                        <br/>
                        Askari Bank Ltd.
                        <br/>
                        <strong>Account Title</strong>
                        TEXTILE TESTING INTERNATIONAL
                        <br/>
                        <strong>Swift Code</strong>
                        ASCMPKKA
                        <br/>
                        <strong>Branch Code</strong>
                        718
                        <br/>
                        <strong>Account No</strong>
                        3890000024
                        <br/>
                        <strong>IBAN</strong>
                        'PK80 ASCM 000718 3890000024
                        <br/>
                        WHIT @ 6%
                    </t>
                    <t t-elif="o.partner_id and o.partner_id.state_id and o.partner_id.state_id.name == 'International'">
