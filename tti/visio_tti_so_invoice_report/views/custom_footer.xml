                        <br/>
                        Meezan Bank Limited
                        <br/>
                        <strong>Account Title</strong>
                        TEXTILE TESTING INTERNATIONAL
                        <br/>
                        <strong>Swift Code</strong>
                        MEZNPKKA
                        <br/>
                        <strong>Branch Code</strong>
                        0233
                        <br/>
                        <strong>Account No</strong>
                        0110636520
                        <br/>
                        <strong>IBAN</strong>
                        PK21MEZN0002330110636520
                        <br/>
                        WHIT @ 6%
                    </t>
                    <t t-elif="o.partner_id and o.partner_id.state_id and o.partner_id.state_id.name == 'Sindh'">
                        <strong>Banking Remittance:</strong>
                        <br/>
                        MCB Islamic Bank Limited
                        <br/>
                        <strong>Account Title</strong>
                        TEXTILE TESTING INTERNATIONAL
                        <br/>
                        <strong>Swift Code</strong>
                        MCIBPKKI
                        <br/>
                        <strong>Branch Code</strong>
                        167
                        <br/>
                        <strong>Account No</strong>
