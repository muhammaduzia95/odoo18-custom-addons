    <template id="tti_external_layout_standard_footer" inherit_id="web.external_layout_standard">
        <xpath expr="//div[contains(@t-attf-class,'footer')]" position="replace">
            <!-- salary report wins first -->
            <t t-if="is_salary_report">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer_salary"/>
            </t>

            <t t-elif="o and o._name in ['purchase.order', 'stock.picking' , 'employee.purchase.requisition']">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer_purchase_order"/>
            </t>

            <t t-elif="o and o._name == 'account.move' and o.move_type == 'entry'">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer_journal_entries"/>
            </t>

            <!-- keep this if you like, but it's no longer required for salary -->
            <t t-elif="o and o._name == 'hr.payslip'">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer_salary"/>
            </t>

            <t t-elif="o and o._name in ['account.move' , 'sale.order']">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer"/>
            </t>

            <t t-else="">
                <t t-call="visio_tti_so_invoice_report.tti_custom_footer_purchase_order"/>
            </t>
        </xpath>


    </template>

