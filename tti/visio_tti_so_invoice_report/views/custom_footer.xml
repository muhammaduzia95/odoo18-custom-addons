                    <t t-if="o.partner_id and o.partner_id.state_id and o.partner_id.state_id.name == 'Punjab'">
                        <strong>Banking Remittance:</strong>
                        <br/>
                        <t t-if="o.company_id.bank_name">
                            <span>
                                <t t-esc="o.company_id.bank_name"/>
                            </span>
                        </t>
                        <br/>
                        <strong>Account Title</strong>
                        <t t-if="o.company_id.account_title">
                            <span>
                                <t t-esc="o.company_id.account_title"/>
                            </span>
                        </t>
                        <br/>
                        <strong>Swift Code</strong>
                        <t t-if="o.company_id.swift_code">
                            <span>
                                <t t-esc="o.company_id.swift_code"/>
                            </span>
                        </t>
                        <br/>
                        <strong>Branch Code</strong>
                        <t t-if="o.company_id.branch_code">
                            <span>
                                <t t-esc="o.company_id.branch_code"/>
                            </span>
                        </t>
                        <br/>
