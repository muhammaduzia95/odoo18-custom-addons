    <!-- Salary Report Footer -->
    <template id="tti_custom_footer_salary">
        <div t-attf-class="footer o_company_#{company.id}_layout"
             style="font-size: 8px; padding-top: 30px;">

            <!-- Signature lines -->
            <div style="width:100%; margin-bottom: 20px;">
                <table style="border-color: white; width:100%; table-layout: fixed; text-align: center; font-size: 10px;">
                    <tr>
                        <td style="width:15%; border-top: 1px solid black; padding-top: 2px;">Prepared By<br/>Asst. Manager HR</td>
                        <td style="width:15%; padding-top: 2px;"></td>
                        <td style="width:15%; border-top: 1px solid black; padding-top: 2px;">Checked By<br/>Manager HR</td>
                        <td style="width:15%; padding-top: 2px;"></td>
                        <td style="width:15%; border-top: 1px solid black; padding-top: 2px;">Checked By<br/>Manager Accounts</td>
                        <td style="width:15%; padding-top: 2px;"></td>
                        <td style="width:15%; border-top: 1px solid black; padding-top: 2px;">Reviewed By<br/>GM Accounts &amp; Finance</td>
                        <td style="width:15%; padding-top: 2px;"></td>
                        <td style="width:15%; border-top: 1px solid black; padding-top: 2px;">Approved By<br/>CEO</td>
                    </tr>
                </table>
            </div>

            <!-- Website + Page Info -->
            <div class="align-items-center"
                 style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid black; padding-top: 5px;">

                <!-- Left side (website) -->
                <div style="flex: 1; text-align: left; vertical-align: middle;">
                    <t t-esc="company.website"/>
                </div>

                <!-- Center (Page X of XX) -->
                <div style="flex: 1; text-align: center; vertical-align: middle;">
                    <t t-if="report_type == 'pdf'">
                        Page
                        <span class="page"/>
                        of
                        <span class="topage"/>
                    </t>
                </div>

                <!-- Right side (print datetime) -->
                <div style="flex: 1; text-align: right; vertical-align: middle;">
                    Printed on:
                    <t t-esc="datetime.datetime.now().strftime('%d-%m-%Y %H:%M')"/>
                </div>
            </div>
        </div>
    </template>


