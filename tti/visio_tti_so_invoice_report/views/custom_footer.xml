                    <p style="margin: 0;">payments@ttilabs.net</p>
                    <br/>
                    <p style="margin: 0;">All services provided by Textile Testing International are governed by the
                        terms and conditions set forth:
                    </p>
                    <p style="margin: 0;">ttilabs.net/terms-and-conditions/</p>
                </div>

                <!-- Middle Column -->
                <div style="width: 32%;">
                    <strong>Postal Remittance:</strong>
                    <br/>
                    Textile Testing International
                    <br/>
                    347-S, Quaid-e-Azam Industrial Estate,
                    <br/>
                    Kot Lakhpat
                    <br/>
                    Lahore, Punjab 54770
                    <br/>
                    Pakistan
                    <br/>
                    <br/>
                    <strong>Make all cheques payable to Textile Testing International</strong>
                </div>

                <!-- Right Column -->
