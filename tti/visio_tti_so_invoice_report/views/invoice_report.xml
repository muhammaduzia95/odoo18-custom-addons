<odoo>
    <template id="custom_invoice_report_from_saleorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="sale_order" t-value="o.env['sale.order'].search([('invoice_ids', 'in', [o.id])], limit=1)"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <div class="d-flex justify-content-between" style="margin-bottom: 30px; font-size:12px;">
                            <!-- Left column: Bill To -->
                            <div style="">
                                <p style="margin: 0;">Bill To:</p>
                                <p style="margin: 0;">
                                    <t t-esc="sale_order.partner_id.name if sale_order else o.partner_id.name"/>
                                </p>

                                <!-- NTN -->
                                <t t-if="(sale_order and sale_order.partner_id.vat) or o.partner_id.vat">
                                    <p style="margin: 0;">NTN:
                                        <span t-esc="sale_order.partner_id.vat if sale_order else o.partner_id.vat"/>
                                    </p>
                                </t>

                                <!-- STRN -->
                                <t t-if="(sale_order and sale_order.partner_id.strn) or o.partner_id.strn">
                                    <p style="margin: 0;">STRN:
                                        <span t-esc="sale_order.partner_id.strn if sale_order else o.partner_id.strn"/>
                                    </p>
                                </t>

                                <!-- Address -->
                                <p style="margin: 0;">
                                    <t t-if="(sale_order and sale_order.partner_id.street) or o.partner_id.street">
                                        <t t-esc="(sale_order.partner_id.street if sale_order else o.partner_id.street)"/>
                                        ,
                                    </t>
                                    <t t-if="(sale_order and sale_order.partner_id.street2) or o.partner_id.street2">
                                        <t t-esc="(sale_order.partner_id.street2 if sale_order else o.partner_id.street2)"/>
                                        ,
                                    </t>
                                    <t t-if="(sale_order and sale_order.partner_id.city) or o.partner_id.city">
                                        <t t-esc="(sale_order.partner_id.city if sale_order else o.partner_id.city)"/>
                                    </t>
                                    <t t-if="(sale_order and sale_order.partner_id.state_id) or o.partner_id.state_id">
                                        -
                                        <t t-esc="(sale_order.partner_id.state_id.name if sale_order else o.partner_id.state_id.name)"/>
                                    </t>
                                    <t t-if="(sale_order and sale_order.partner_id.zip) or o.partner_id.zip">
                                        -
                                        <t t-esc="(sale_order.partner_id.zip if sale_order else o.partner_id.zip)"/>
                                    </t>
                                    <t t-if="(sale_order and sale_order.partner_id.country_id) or o.partner_id.country_id">
                                        ,
                                        <t t-esc="(sale_order.partner_id.country_id.name if sale_order else o.partner_id.country_id.name)"/>
                                    </t>
                                </p>

                                <!-- Applicant name & phone -->
                                <t t-if="sale_order.tti_pi_applicant.name">
                                    <p style="margin: 0;" t-esc="sale_order.tti_pi_applicant.name"/>
                                </t>
                                <t t-if="sale_order.tti_pi_applicant.phone">
                                    <p style="margin: 0;" t-esc="sale_order.tti_pi_applicant.phone"/>
                                </t>
                            </div>

                            <!-- Right column: Sample Info -->
                            <div style="text-align: left;max-width: 250px;">
                                <t t-if="sale_order.tti_si_category">
                                    <p style="margin: 0;">
                                        <span>Sample Category:</span>
                                        <span t-esc="sale_order.tti_si_category.name"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_description">
                                    <p style="margin: 0;">
                                        <span>Sample Description:</span>
                                        <span t-esc="sale_order.tti_si_description"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_pi_buyer">
                                    <p style="margin: 0;">
                                        <span>Buyer:</span>
                                        <span t-esc="sale_order.tti_pi_buyer.name"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_pi_agent_id">
                                    <p style="margin: 0;">
                                        <span>Agent:</span>
                                        <span t-esc="sale_order.tti_pi_agent_id.name"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_style_no">
                                    <p style="margin: 0;">
                                        <span>Style Number:</span>
                                        <span t-esc="sale_order.tti_si_style_no"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_fabric">
                                    <p style="margin: 0;">
                                        <span>Fabric :</span>
                                        <span t-esc="sale_order.tti_si_fabric"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_colour">
                                    <p style="margin: 0;">
                                        <span>Color :</span>
                                        <span t-esc="sale_order.tti_si_colour"/>
                                    </p>
                                </t>
                                <t t-if="o.ref">
                                    <p style="margin: 0;">
                                        <span>Vendor Ref :</span>
                                        <span t-esc="o.ref"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_po">
                                    <p style="margin: 0;">
                                        <span>PO :</span>
                                        <span t-esc="sale_order.tti_si_po"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_design">
                                    <p style="margin: 0;">
                                        <span>Design :</span>
                                        <span t-esc="sale_order.tti_si_design"/>
                                    </p>
                                </t>

                                <!-- Dynamic Labels -->
                                <t t-if="sale_order.tti_si_label_1_name or sale_order.tti_si_label_1_value">
                                    <p style="margin: 0;">
                                        <span t-if="sale_order.tti_si_label_1_name"
                                              t-esc="sale_order.tti_si_label_1_name"/>:
                                        <span t-if="sale_order.tti_si_label_1_value"
                                              t-esc="sale_order.tti_si_label_1_value"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_label_2_name or sale_order.tti_si_label_2_value">
                                    <p style="margin: 0;">
                                        <span t-if="sale_order.tti_si_label_2_name"
                                              t-esc="sale_order.tti_si_label_2_name"/>:
                                        <span t-if="sale_order.tti_si_label_2_value"
                                              t-esc="sale_order.tti_si_label_2_value"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_label_3_name or sale_order.tti_si_label_3_value">
                                    <p style="margin: 0;">
                                        <span t-if="sale_order.tti_si_label_3_name"
                                              t-esc="sale_order.tti_si_label_3_name"/>:
                                        <span t-if="sale_order.tti_si_label_3_value"
                                              t-esc="sale_order.tti_si_label_3_value"/>
                                    </p>
                                </t>
                                <t t-if="sale_order.tti_si_label_4_name or sale_order.tti_si_label_4_value">
                                    <p style="margin: 0;">
                                        <span t-if="sale_order.tti_si_label_4_name"
                                              t-esc="sale_order.tti_si_label_4_name"/>:
                                        <span t-if="sale_order.tti_si_label_4_value"
                                              t-esc="sale_order.tti_si_label_4_value"/>
                                    </p>
                                </t>
                            </div>
                        </div>

                        <!-- Sale Invoice Heading -->
                        <div style="margin-bottom: 20px;">
                            <h2 style="color: #2E69A6; margin: 0;">
                                <t t-if="o.state == 'draft'">Draft Invoice #</t>
                                <t t-if="o.state == 'posted'">Sale Tax Invoice #</t>
                                <t t-esc="o.name"/>
                            </h2>
                        </div>

                        <!-- Invoice Meta Info Row -->
                        <div class="d-flex"
                             style="display: flex; flex-direction:row; justify-content: space-between; margin-bottom: 20px; gap:30px;">
                            <!-- Quotation Reference -->
                            <div style="margin-right:60px;">
                                <p style="margin: 0;">
                                    <strong>Sale Order Reference #:</strong>
                                </p>
                                <p style="margin: 0;">
                                    <t t-esc="sale_order.name"/>
                                </p>
                            </div>

                            <!-- Date -->
                            <div style="margin-right:60px;">
                                <p style="margin: 0;">
                                    <strong>Invoice Date:</strong>
                                </p>
                                <p style="margin: 0;" t-if="o.invoice_date">
                                    <t t-esc="o.invoice_date.strftime('%d/%m/%Y')"/>
                                </p>
                            </div>

                            <!-- Payment Terms -->
                            <!-- <t t-if="o.invoice_payment_term_id">
                                <div style="margin-right:60px;">
                                    <p style="margin: 0;">
                                        <strong>Payment Terms:</strong>
                                    </p>
                                    <p style="margin: 0;" t-if="o.invoice_payment_term_id">
                                        <t t-esc="o.invoice_payment_term_id.name"/>
                                    </p>
                                </div>
                            </t>

                            <div style="margin-right:60px;">
                                <p style="margin: 0;">
                                    <strong>Payment Due By:</strong>
                                </p>
                                <p style="margin: 0;">
                                    <t t-esc="o.invoice_date_due.strftime('%d/%m/%Y')"/>
                                </p>
                            </div> -->

                        </div>

                        <!-- Test Table Section -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 12px;">
                            <!-- Header Row -->
                            <thead>
                                <tr style="background-color: #2E69A6; color: white; text-align: left;">
                                    <t t-set="index" t-value="1"/>
                                    <t t-set="currency" t-value="o.currency_id"/>
                                    <t t-set="currency_name" t-value="o.currency_id.name"/>
                                    <th style="padding: 8px; border: 1px solid black;">Sr #</th>
                                    <th style="padding: 8px; border: 1px solid black;">Test Name</th>
                                    <th style="padding: 8px; border: 1px solid black; text-align: right;">Qty</th>
                                    <th style="padding: 8px; border: 1px solid black; text-align: right;">Rate USD
                                    </th>
                                    <th style="padding: 8px; color: white; border: 1px solid black; text-align: right;">
                                        Total USD
                                    </th>
                                    <t t-if="currency_name == 'PKR'">
                                        <th style="padding: 8px; color: white; width:8%; border: 1px solid black; text-align: right;">
                                            Total
                                            PKR
                                        </th>
                                    </t>
                                    <t t-elif="currency_name == 'EUR'">
                                        <th style="padding: 8px; color: white; width:8%; border: 1px solid black; text-align: right;">
                                            Total
                                            Euro
                                        </th>
                                    </t>
                                </tr>
                            </thead>

                            <!-- Body Rows -->
                            <tbody>
                                <tr t-foreach="o.invoice_line_ids" t-as="line">
                                    <t t-if="line.product_id.name not in [
                                            'Express Charges',
                                            'Shuttle Service Charges',
                                            'Import Duty Charges',
                                            'Courier Charge',
                                            'Travelling Charges',
                                            'Discount'
                                        ] and line.display_type not in ['line_section', 'line_note']">
                                        <td style="padding: 6px; border: 1px solid black;">
                                            <t t-esc="index"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid black;">
                                            <t t-esc="line.product_id.name"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid black; text-align: right;">
                                            <t t-esc="int(line.quantity)"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid black; text-align: right;">
                                            <t t-esc="line.price_unit_rate"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                        </td>
                                        <td style="padding: 6px; border: 1px solid black; text-align: right;">
                                            <t t-esc="(line.price_unit_rate * line.quantity)"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                        </td>
                                        <t t-if="currency_name in ['PKR', 'EUR']">
                                            <td style="padding: 6px; border: 1px solid black; text-align: right;">
                                                <t t-esc="(line.quantity * line.price_unit)"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                            </td>
                                        </t>
                                        <t t-set="index" t-value="index + 1"/>
                                    </t>
                                </tr>
                            </tbody>
                        </table>


                        <!-- Footer Block: Notes + Totals -->
                        <div class="d-flex justify-content-between"
                             style="display: flex; justify-content: space-between; margin-top: 30px; font-size: 12px;">

                            <!-- Left: Special Notes -->
                            <div style="width: 50%; margin-right:150px;">
                                <div style="background-color: #2E69A6; color: white; padding: 5px 10px; font-weight: bold;">
                                    Special Notes or Instructions
                                </div>
                                <div style="border: 1px solid #2E69A6; border-top: none; padding: 10px;">
                                    <p style="margin: 0;">
                                        - Exchange Rate (USD to PKR):
                                        <t t-esc="sale_order.tti_dollar_exchange_rate"
                                           t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                    </p>
                                </div>
                            </div>

                            <!-- Right: Totals Table -->
                            <div style="width: 30%; align-items:flex-end;">
                                <table class="table-sm table-borderless"
                                       style="width: 100%; font-size: 12px;">
                                    <t t-set="dollar_exchange_rate" t-value="sale_order.tti_dollar_exchange_rate"/>
                                    <t t-set="excluded_products" t-value="[
                                        'Express Charges',
                                        'Shuttle Service Charges',
                                        'Import Duty Charges',
                                        'Courier Charge',
                                        'Travelling Charges',
                                        'Discount'
                                    ]"/>
                                    <t t-set="total_usd"
                                       t-value="sum(line.price_unit_rate * line.quantity for line in o.invoice_line_ids if line.product_id.name not in excluded_products)"/>
                                    <t t-set="total_pkr"
                                       t-value="sum(line.price_unit * line.quantity for line in o.invoice_line_ids if line.product_id.name not in excluded_products)"/>
                                    <!-- USD Discount -->
                                    <t t-set="usd_discount"
                                       t-value="sum(((line.discount/100) * (line.price_unit_rate * line.quantity) ) for line in o.invoice_line_ids) +
                                         sum(abs((line.price_unit_rate * line.quantity)) for line in o.invoice_line_ids if line.product_id.name == 'Discount')"
                                    />
                                    <!-- PKR Discount -->
                                    <t t-set="pkr_discount"
                                       t-value="sum(((line.discount/100) * (line.price_unit * line.quantity)) for line in o.invoice_line_ids) +
                                        sum(abs((line.price_unit * line.quantity)) for line in o.invoice_line_ids if line.product_id.name == 'Discount')"/>
                                    <t t-set="tax_name"
                                       t-value="o.invoice_line_ids[0].tax_ids[0].name if o.invoice_line_ids and o.invoice_line_ids[0].tax_ids else ''"/>
                                    <t t-set="tax_percent"
                                       t-value="o.invoice_line_ids[0].tax_ids[0].amount if o.invoice_line_ids and o.invoice_line_ids[0].tax_ids else 0.0"/>
                                    <t t-set="tax_pkr" t-value="o.amount_untaxed * (tax_percent / 100)"/>
                                    <t t-set="tax_usd" t-value="tax_pkr/dollar_exchange_rate"/>
                                    <t t-set="charge_names"
                                       t-value="['Express Charges', 'Shuttle Service Charges', 'Import Duty Charges', 'Courier Charge', 'Travelling Charges']"/>
                                    <t t-set="charge_usd_total"
                                       t-value="sum(line.price_unit_rate * line.quantity for line in o.invoice_line_ids if line.product_id.name in charge_names)"/>
                                    <t t-set="charge_pkr_total"
                                       t-value="sum((line.price_unit * line.quantity) for line in o.invoice_line_ids if line.product_id.name in charge_names)"/>
                                    <tr>
                                        <td>
                                            <strong>Total</strong>
                                        </td>
                                        <td style="text-align: right; ">
                                            <t t-esc="total_usd"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                            $
                                        </td>
                                        <t t-if="currency_name == 'PKR'">
                                            <td style="text-align: right; ">
                                                <t t-esc="total_pkr"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                Rs.
                                            </td>
                                        </t>
                                        <t t-if="currency_name == 'EUR'">
                                            <td style="text-align: right; ">
                                                <t t-esc="total_pkr"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                €
                                            </td>
                                        </t>
                                    </tr>
                                    <tr t-foreach="o.invoice_line_ids" t-as="line">
                                        <t t-if="line.product_id.name in charge_names">
                                            <tr>
                                                <td>
                                                    <t t-esc="line.product_id.name"/>
                                                </td>

                                                <!-- USD -->
                                                <td style="text-align: right;">
                                                    <t t-esc="(line.price_unit_rate * line.quantity)"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    $
                                                </td>

                                                <!-- PKR -->
                                                <t t-if="currency_name == 'PKR'">
                                                    <td style="text-align: right;">
                                                        <t t-esc="line.price_subtotal"
                                                           t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                        Rs.
                                                    </td>
                                                </t>

                                                <!-- EUR -->
                                                <t t-if="currency_name == 'EUR'">
                                                    <td style="text-align: right;">
                                                        <t t-esc="line.price_subtotal"
                                                           t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                        €
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                    </tr>
                                    <t t-if="usd_discount != 0.0 or pkr_discount != 0.0">
                                        <tr>
                                            <td>Discount</td>

                                            <!-- USD -->
                                            <td style="text-align: right; border-bottom:1px solid black;">
                                                -
                                                <t t-esc="usd_discount"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                $
                                            </td>

                                            <!-- PKR -->
                                            <t t-if="currency_name == 'PKR'">
                                                <td style="text-align: right; border-bottom:1px solid black;">
                                                    -
                                                    <t t-esc="pkr_discount"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    Rs.
                                                </td>
                                            </t>

                                            <!-- EUR -->
                                            <t t-if="currency_name == 'EUR'">
                                                <td style="text-align: right; border-bottom:1px solid black;">
                                                    -
                                                    <t t-esc="pkr_discount"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    €
                                                </td>
                                            </t>
                                        </tr>
                                        <tr>
                                            <td>
                                                <strong>Sub Total</strong>
                                            </td>

                                            <!-- USD -->
                                            <td style="text-align: right;">
                                                <t t-esc="((total_usd + charge_usd_total) - usd_discount)"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                $
                                            </td>

                                            <!-- PKR -->
                                            <t t-if="currency_name == 'PKR'">
                                                <td style="text-align: right;">
                                                    <t t-esc="((total_pkr + charge_pkr_total) - pkr_discount)"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    Rs.
                                                </td>
                                            </t>

                                            <!-- EUR -->
                                            <t t-if="currency_name == 'EUR'">
                                                <td style="text-align: right;">
                                                    <t t-esc="((total_pkr + charge_pkr_total) - pkr_discount)"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    €
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                    <t t-if="tax_name">
                                        <tr>
                                            <td>
                                                <t t-esc="tax_name"/>
                                            </td>

                                            <!-- USD -->
                                            <td style="text-align: right;">
                                                <t t-esc="tax_usd"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                $
                                            </td>

                                            <!-- PKR -->
                                            <t t-if="currency_name == 'PKR'">
                                                <td style="text-align: right;">
                                                    <t t-esc="tax_pkr"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    Rs.
                                                </td>
                                            </t>

                                            <!-- EUR -->
                                            <t t-if="currency_name == 'EUR'">
                                                <td style="text-align: right;">
                                                    <t t-esc="tax_pkr"
                                                       t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                    €
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                    <tr style="background-color: #2E69A6; color: white; font-weight: bold;">
                                        <td>Net Payable</td>

                                        <!-- USD -->
                                        <td style="text-align: right;">
                                            <t t-esc="(tax_usd + charge_usd_total + (total_usd - usd_discount))"
                                               t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                            $
                                        </td>

                                        <!-- PKR -->
                                        <t t-if="currency_name == 'PKR'">
                                            <td style="text-align: right;">
                                                <t t-esc="(tax_pkr + charge_pkr_total + (total_pkr - pkr_discount))"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                Rs.
                                            </td>
                                        </t>

                                        <!-- EUR -->
                                        <t t-if="currency_name == 'EUR'">
                                            <td style="text-align: right;">
                                                <t t-esc="(tax_pkr + charge_pkr_total + (total_pkr - pkr_discount))"
                                                   t-options="{'widget': 'float', 'precision': 2, 'thousand_sep': true}"/>
                                                €
                                            </td>
                                        </t>
                                    </tr>
                                </table>
                            </div>
                        </div>


                        <!--                        <t t-if="sale_order.tti_attachment_ids">-->
                        <!--                            <div style="background-color: #2E69A6; width: 50%%; color: white; padding: 5px 10px; font-weight: bold; margin-top:20px;">-->
                        <!--                                Attached Images-->
                        <!--                            </div>-->
                        <!--                            <table class="table table-borderless"-->
                        <!--                                   style="width: 100%; border-collapse: collapse; margin-top: 10px;">-->
                        <!--                                <tr t-foreach="sale_order.tti_attachment_ids" t-as="img">-->
                        <!--                                    <t t-if="img.mimetype and img.mimetype.startswith('image/')">-->
                        <!--                                        <td style="padding: 10px;  text-align: left;">-->
                        <!--                                            <img t-att-src="'data:image/png;base64,%s' % img.datas.decode('utf-8')"-->
                        <!--                                                 alt="Attachment"-->
                        <!--                                                 style="max-width: 150px; max-height: 150px;"/>-->
                        <!--                                        </td>-->
                        <!--                                    </t>-->
                        <!--                                </tr>-->
                        <!--                            </table>-->
                        <!--                        </t>-->

                        <div class="d-flex justify-content-end" style="margin-top: 100px;">
                            <div style="width:35%; border-top:1px solid black;">
                                <span>Signature</span>
